    local loadBarFill = Create("Frame", {
        Name = "Fill",
        BackgroundColor3 = theme.Accent,
        Size = UDim2.new(0, 0, 1, 0),
        Parent = loadBarBg,
    })
    AddCorner(loadBarFill, 2)
    AddGradient(loadBarFill, ColorSequence.new({
        ColorSequenceKeypoint.new(0, theme.Accent),
        ColorSequenceKeypoint.new(1, theme.AccentHover),
    }))
    
    local loadVersion = Create("TextLabel", {
        Name = "Version",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16),
        Position = UDim2.new(0, 0, 0.35, 76),
        Text = Release,
        TextColor3 = theme.TextMuted,
        TextSize = 10,
        FontFace = theme.FontFace,
        Parent = loadingFrame,
    })
    
    -- Loading animation
    task.spawn(function()
        Tween(loadBarFill, 1.2, { Size = UDim2.new(1, 0, 1, 0) }, Enum.EasingStyle.Quart)
        task.wait(1.5)
        Tween(loadingFrame, 0.5, { BackgroundTransparency = 1 })
        Tween(loadingTitle, 0.3, { TextTransparency = 1 })
        Tween(loadingSubtitle, 0.3, { TextTransparency = 1 })
        Tween(loadVersion, 0.3, { TextTransparency = 1 })
        Tween(loadBarBg, 0.3, { BackgroundTransparency = 1 })
        Tween(loadBarFill, 0.3, { BackgroundTransparency = 1 })
        task.wait(0.5)
        loadingFrame:Destroy()
    end)
    
    -- ═══════════════════════════════════════════════════════
    -- TAB SYSTEM
    -- ═══════════════════════════════════════════════════════
    
    local tabs = {}
    local currentTab = nil
    local tabPages = {}
    local Window = {}
    
    function Window:CreateTab(tabSettings)
        local tabName = tabSettings.Name or tabSettings
        local tabIcon = tabSettings.Icon or nil
        
        -- Tab button in sidebar
        local tabBtn = Create("TextButton", {
            Name = tabName,
            BackgroundColor3 = theme.TabBackground,
            BackgroundTransparency = 0.5,
            Size = UDim2.new(1, 0, 0, 32),
            Text = "",
            AutoButtonColor = false,
            Parent = tabListScroll,
        })
        AddCorner(tabBtn, 8)
        
        -- Tab icon
        if tabIcon then
            Create("TextLabel", {
                Name = "Icon",
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 24, 1, 0),
                Position = UDim2.new(0, 8, 0, 0),
                Text = tabIcon,
                TextSize = 14,
                Parent = tabBtn,
            })
        end
        
        -- Tab title
        local tabTitle = Create("TextLabel", {
            Name = "Title",
            BackgroundTransparency = 1,
            Size = UDim2.new(1, tabIcon and -40 or -16, 1, 0),
            Position = UDim2.new(0, tabIcon and 32 or 10, 0, 0),
            Text = tabName,
            TextColor3 = theme.TabText,
            TextSize = 12,
            FontFace = theme.FontFace,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd,
            Parent = tabBtn,
        })
        
        -- Active indicator
        local activeIndicator = Create("Frame", {
            Name = "ActiveIndicator",
            BackgroundColor3 = theme.Accent,
            Size = UDim2.new(0, 3, 0, 0),
            Position = UDim2.new(0, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0, 0.5),
            Parent = tabBtn,
        })
        AddCorner(activeIndicator, 2)
        
        -- Tab page
        local tabPage = Create("ScrollingFrame", {
            Name = tabName,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = theme.ScrollbarColor,
            ScrollBarImageTransparency = 0.3,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            BorderSizePixel = 0,
            Visible = false,
            Parent = contentArea,
        })
        AddListLayout(tabPage, 6)
        AddPadding(tabPage, 8, 10, 8, 10)
        
        tabPages[tabName] = tabPage
        
        -- Tab selection
        local function selectTab()
            for _, otherBtn in ipairs(tabListScroll:GetChildren()) do
                if otherBtn:IsA("TextButton") then
                    Tween(otherBtn, 0.25, { BackgroundTransparency = 0.5, BackgroundColor3 = theme.TabBackground })
                    local otherTitle = otherBtn:FindFirstChild("Title")
                    if otherTitle then
                        Tween(otherTitle, 0.25, { TextColor3 = theme.TabText })
                    end
                    local otherIndicator = otherBtn:FindFirstChild("ActiveIndicator")
                    if otherIndicator then
                        Tween(otherIndicator, 0.25, { Size = UDim2.new(0, 3, 0, 0) })
                    end
                end
            end
            
            for _, page in pairs(tabPages) do
                page.Visible = false
            end
            
            Tween(tabBtn, 0.25, { BackgroundTransparency = 0.1, BackgroundColor3 = LerpColor(theme.TabBackground, theme.Accent, 0.15) })
            Tween(tabTitle, 0.25, { TextColor3 = theme.TextPrimary })
            Tween(activeIndicator, 0.3, { Size = UDim2.new(0, 3, 0, 18) })
            
            tabPage.Visible = true
            currentTab = tabName
        end
        
        tabBtn.MouseEnter:Connect(function()
            if currentTab ~= tabName then
                Tween(tabBtn, 0.2, { BackgroundTransparency = 0.3 })
            end
        end)
        
        tabBtn.MouseLeave:Connect(function()
            if currentTab ~= tabName then
                Tween(tabBtn, 0.2, { BackgroundTransparency = 0.5 })
            end
        end)
        
        tabBtn.MouseButton1Click:Connect(selectTab)
        
        if #tabs == 0 then
            task.defer(selectTab)
        end
        
        table.insert(tabs, tabName)
        
        -- ═══════════════════════════════════════════════════
        -- ELEMENT CREATION METHODS
        -- ═══════════════════════════════════════════════════
        
        local Tab = {}
        
        -- ─── SECTION ────────────────────────────────────
        function Tab:CreateSection(sectionName)
            local sectionValue = {}
            
            local section = Create("Frame", {
                Name = "Section_" .. sectionName,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 24),
                Parent = tabPage,
            })
            
            local sectionTitle = Create("TextLabel", {
                Name = "Title",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -16, 1, 0),
                Position = UDim2.new(0, 8, 0, 0),
                Text = string.upper(sectionName),
                TextColor3 = theme.TextMuted,
                TextSize = 10,
                FontFace = theme.FontFaceBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = section,
            })
            
            Create("Frame", {
                BackgroundColor3 = theme.DividerColor,
                Size = UDim2.new(1, -16, 0, 1),
                Position = UDim2.new(0, 8, 1, -1),
                BorderSizePixel = 0,
                Parent = section,
            })
            
            function sectionValue:Set(newName)
                sectionTitle.Text = string.upper(newName)
            end
            
            return sectionValue
        end
        
        -- ─── LABEL ──────────────────────────────────────
        function Tab:CreateLabel(labelText)
            local labelValue = {}
            
            local label = Create("Frame", {
                Name = "Label",
                BackgroundColor3 = theme.ElementBackground,
                BackgroundTransparency = 0.3,
                Size = UDim2.new(1, 0, 0, 36),
                Parent = tabPage,
            })
            AddCorner(label, 8)
            AddStroke(label, theme.ElementBorder, 1, 0.5)
            
            local labelTitle = Create("TextLabel", {
                Name = "Title",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -20, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                Text = labelText,
                TextColor3 = theme.TextSecondary,
                TextSize = 13,
                FontFace = theme.FontFace,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = label,
            })
            
            function labelValue:Set(newText)
                labelTitle.Text = newText
            end
            
            return labelValue
        end
        
        -- ─── PARAGRAPH ──────────────────────────────────
        function Tab:CreateParagraph(paragraphSettings)
            local paragraphValue = {}
            
            local paragraph = Create("Frame", {
                Name = "Paragraph",
                BackgroundColor3 = theme.ElementBackground,
                BackgroundTransparency = 0.3,
                Size = UDim2.new(1, 0, 0, 70),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = tabPage,
            })
            AddCorner(paragraph, 8)
