        TextSize = 20,
        FontFace = theme.FontFaceBold,
        Parent = loadingFrame,
    })
    
    local loadingSubtitle = Create("TextLabel", {
        Name = "Subtitle",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 20),
        Position = UDim2.new(0, 0, 0.35, 32),
        Text = settings.LoadingSubtitle or "Loading...",
        TextColor3 = theme.TextSecondary,
