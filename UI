                FontFace = theme.FontFace,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = dropdown,
            })
            
            local selectedLabel = Create("TextLabel", {
                Name = "Selected",
                BackgroundTransparency = 1,
                Size = UDim2.new(0.45, -30, 0, 38),
                Position = UDim2.new(0.5, 0, 0, 0),
                Text = #dropdownSettings.CurrentOption > 0 and dropdownSettings.CurrentOption[1] or "None",
                TextColor3 = theme.TextSecondary,
                TextSize = 12,
                FontFace = theme.FontFace,
                TextXAlignment = Enum.TextXAlignment.Right,
                TextTruncate = Enum.TextTruncate.AtEnd,
                Parent = dropdown,
            })
            
            local arrow = Create("TextLabel", {
                Name = "Arrow",
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 20, 0, 38),
                Position = UDim2.new(1, -24, 0, 0),
                Text = "▼",
                TextColor3 = theme.TextMuted,
                TextSize = 10,
                Rotation = 0,
                Parent = dropdown,
            })
            
            local optionsContainer = Create("Frame", {
                Name = "Options",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -12, 0, 0),
                Position = UDim2.new(0, 6, 0, 42),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = dropdown,
            })
            AddListLayout(optionsContainer, 2)
            
            local function updateSelectedText()
                if dropdownSettings.MultipleOptions then
                    if #dropdownSettings.CurrentOption == 0 then
                        selectedLabel.Text = "None"
                    elseif #dropdownSettings.CurrentOption == 1 then
                        selectedLabel.Text = dropdownSettings.CurrentOption[1]
                    else
                        selectedLabel.Text = #dropdownSettings.CurrentOption .. " selected"
                    end
                else
                    selectedLabel.Text = dropdownSettings.CurrentOption[1] or "None"
                end
            end
            updateSelectedText()
            
            local function createOption(optionName)
                local isSelected = table.find(dropdownSettings.CurrentOption, optionName) ~= nil
                
                local optionBtn = Create("TextButton", {
                    Name = optionName,
                    BackgroundColor3 = isSelected and LerpColor(theme.DropdownBackground, theme.Accent, 0.15) or theme.DropdownBackground,
                    Size = UDim2.new(1, 0, 0, 30),
                    Text = "",
                    AutoButtonColor = false,
                    Parent = optionsContainer,
                })
                AddCorner(optionBtn, 6)
                
                local optTitle = Create("TextLabel", {
                    Name = "Title",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -30, 1, 0),
                    Position = UDim2.new(0, 10, 0, 0),
                    Text = optionName,
                    TextColor3 = isSelected and theme.Accent or theme.TextSecondary,
                    TextSize = 12,
                    FontFace = theme.FontFace,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = optionBtn,
                })
                
                local checkmark = Create("TextLabel", {
                    Name = "Check",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0, 20, 1, 0),
                    Position = UDim2.new(1, -24, 0, 0),
                    Text = isSelected and "✓" or "",
                    TextColor3 = theme.Accent,
                    TextSize = 12,
                    FontFace = theme.FontFaceBold,
                    Parent = optionBtn,
                })
                
                optionBtn.MouseEnter:Connect(function()
                    Tween(optionBtn, 0.15, { BackgroundColor3 = theme.DropdownItemHover })
                end)
                optionBtn.MouseLeave:Connect(function()
                    local sel = table.find(dropdownSettings.CurrentOption, optionName) ~= nil
                    Tween(optionBtn, 0.15, { BackgroundColor3 = sel and LerpColor(theme.DropdownBackground, theme.Accent, 0.15) or theme.DropdownBackground })
                end)
                
                optionBtn.MouseButton1Click:Connect(function()
                    if dropdownSettings.MultipleOptions then
                        local idx = table.find(dropdownSettings.CurrentOption, optionName)
                        if idx then
                            table.remove(dropdownSettings.CurrentOption, idx)
                            checkmark.Text = ""
                            Tween(optTitle, 0.2, { TextColor3 = theme.TextSecondary })
                            Tween(optionBtn, 0.2, { BackgroundColor3 = theme.DropdownBackground })
                        else
                            table.insert(dropdownSettings.CurrentOption, optionName)
                            checkmark.Text = "✓"
                            Tween(optTitle, 0.2, { TextColor3 = theme.Accent })
                            Tween(optionBtn, 0.2, { BackgroundColor3 = LerpColor(theme.DropdownBackground, theme.Accent, 0.15) })
                        end
                    else
                        dropdownSettings.CurrentOption = {optionName}
                        for _, child in ipairs(optionsContainer:GetChildren()) do
                            if child:IsA("TextButton") then
                                local cTitle = child:FindFirstChild("Title")
                                local cCheck = child:FindFirstChild("Check")
                                if child.Name == optionName then
                                    if cCheck then cCheck.Text = "✓" end
                                    if cTitle then Tween(cTitle, 0.2, { TextColor3 = theme.Accent }) end
                                    Tween(child, 0.2, { BackgroundColor3 = LerpColor(theme.DropdownBackground, theme.Accent, 0.15) })
                                else
                                    if cCheck then cCheck.Text = "" end
                                    if cTitle then Tween(cTitle, 0.2, { TextColor3 = theme.TextSecondary }) end
                                    Tween(child, 0.2, { BackgroundColor3 = theme.DropdownBackground })
                                end
                            end
                        end
                        task.delay(0.15, function()
                            isOpen = false
                            Tween(dropdown, 0.3, { Size = UDim2.new(1, 0, 0, 38) })
                            Tween(arrow, 0.3, { Rotation = 0 })
                        end)
                    end
                    
                    updateSelectedText()
                    pcall(dropdownSettings.Callback, dropdownSettings.CurrentOption)
                    SaveConfiguration()
                end)
                
                return optionBtn
            end
            
            for _, option in ipairs(dropdownSettings.Options or {}) do
                createOption(option)
            end
            
            local interact = Create("TextButton", {
                Name = "Interact",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 38),
                Text = "",
                ZIndex = 5,
                Parent = dropdown,
            })
            
            interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    local optionCount = #(dropdownSettings.Options or {})
                    local targetHeight = 38 + 6 + math.min(optionCount, 5) * 32
                    Tween(dropdown, 0.35, { Size = UDim2.new(1, 0, 0, targetHeight) })
                    Tween(arrow, 0.35, { Rotation = 180 })
                else
                    Tween(dropdown, 0.35, { Size = UDim2.new(1, 0, 0, 38) })
                    Tween(arrow, 0.35, { Rotation = 0 })
                end
            end)
            
            function dropdownSettings:Set(newOptions)
                if typeof(newOptions) == "string" then
                    newOptions = {newOptions}
                end
                dropdownSettings.CurrentOption = newOptions
                updateSelectedText()
                
                for _, child in ipairs(optionsContainer:GetChildren()) do
                    if child:IsA("TextButton") then
                        local sel = table.find(newOptions, child.Name) ~= nil
                        local cTitle = child:FindFirstChild("Title")
                        local cCheck = child:FindFirstChild("Check")
                        if cCheck then cCheck.Text = sel and "✓" or "" end
                        if cTitle then cTitle.TextColor3 = sel and theme.Accent or theme.TextSecondary end
                        child.BackgroundColor3 = sel and LerpColor(theme.DropdownBackground, theme.Accent, 0.15) or theme.DropdownBackground
                    end
                end
                
                pcall(dropdownSettings.Callback, newOptions)
                SaveConfiguration()
            end
            
            if dropdownSettings.Flag then
                Exter.Flags[dropdownSettings.Flag] = dropdownSettings
            end
            
            return dropdownSettings
        end
        
