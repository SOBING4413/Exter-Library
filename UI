                TextSize = 13,
                FontFace = theme.FontFace,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = keybind,
            })
            
            local keybindBox = Create("TextButton", {
                Name = "KeyBox",
                BackgroundColor3 = theme.InputBackground,
                Size = UDim2.new(0, 60, 0, 26),
                Position = UDim2.new(1, -72, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Text = keybindSettings.CurrentKeybind,
                TextColor3 = theme.Accent,
                TextSize = 12,
                FontFace = theme.FontFaceBold,
                AutoButtonColor = false,
                Parent = keybind,
            })
            AddCorner(keybindBox, 6)
            AddStroke(keybindBox, theme.InputBorder, 1, 0.3)
            
            local listening = false
            
            keybindBox.MouseButton1Click:Connect(function()
                listening = true
                keybindBox.Text = "..."
                Tween(keybindBox.UIStroke, 0.2, { Color = theme.Accent })
            end)
            
            UserInputService.InputBegan:Connect(function(input, processed)
                if listening then
                    if input.KeyCode ~= Enum.KeyCode.Unknown then
                        local keyName = input.KeyCode.Name
                        keybindSettings.CurrentKeybind = keyName
                        keybindBox.Text = keyName
                        listening = false
                        Tween(keybindBox.UIStroke, 0.2, { Color = theme.InputBorder })
                        SaveConfiguration()
                    end
                elseif not processed and keybindSettings.CurrentKeybind then
                    if input.KeyCode == Enum.KeyCode[keybindSettings.CurrentKeybind] then
                        pcall(keybindSettings.Callback)
                    end
                end
            end)
            
            keybind.MouseEnter:Connect(function()
                Tween(keybind, 0.25, { BackgroundColor3 = theme.ElementBackgroundHover })
            end)
            keybind.MouseLeave:Connect(function()
                Tween(keybind, 0.25, { BackgroundColor3 = theme.ElementBackground })
            end)
            
            function keybindSettings:Set(newKey)
                keybindSettings.CurrentKeybind = newKey
                keybindBox.Text = newKey
                SaveConfiguration()
            end
            
            if keybindSettings.Flag then
                Exter.Flags[keybindSettings.Flag] = keybindSettings
            end
            
            return keybindSettings
        end
        
        -- ─── COLOR PICKER ───────────────────────────────
        function Tab:CreateColorPicker(colorPickerSettings)
            colorPickerSettings.Type = "ColorPicker"
            colorPickerSettings.Color = colorPickerSettings.Color or Color3.fromRGB(255, 255, 255)
            
            local isOpen = false
            local h, s, v = colorPickerSettings.Color:ToHSV()
            
            local cpFrame = Create("Frame", {
                Name = "ColorPicker_" .. (colorPickerSettings.Name or "ColorPicker"),
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, 0, 0, 38),
                ClipsDescendants = true,
                Parent = tabPage,
            })
            AddCorner(cpFrame, 8)
            AddStroke(cpFrame, theme.ElementBorder, 1, 0.3)
            
            Create("TextLabel", {
                Name = "Title",
                BackgroundTransparency = 1,
                Size = UDim2.new(0.6, 0, 0, 38),
                Position = UDim2.new(0, 12, 0, 0),
                Text = colorPickerSettings.Name or "Color Picker",
                TextColor3 = theme.TextPrimary,
                TextSize = 13,
                FontFace = theme.FontFace,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = cpFrame,
            })
            
            local colorPreview = Create("Frame", {
                Name = "Preview",
                BackgroundColor3 = colorPickerSettings.Color,
                Size = UDim2.new(0, 28, 0, 22),
                Position = UDim2.new(1, -40, 0, 8),
                Parent = cpFrame,
            })
            AddCorner(colorPreview, 6)
            AddStroke(colorPreview, theme.ElementBorder, 1, 0.3)
            
            local pickerArea = Create("Frame", {
                Name = "PickerArea",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -16, 0, 120),
                Position = UDim2.new(0, 8, 0, 44),
                Parent = cpFrame,
            })
            
            local svPicker = Create("ImageLabel", {
                Name = "SVPicker",
                BackgroundColor3 = Color3.fromHSV(h, 1, 1),
                Size = UDim2.new(1, -30, 0, 90),
                Image = "rbxassetid://11415645739",
                Parent = pickerArea,
            })
            AddCorner(svPicker, 6)
            
            local svPoint = Create("Frame", {
                Name = "Point",
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(0, 12, 0, 12),
                Position = UDim2.new(s, -6, 1 - v, -6),
                ZIndex = 5,
                Parent = svPicker,
            })
            AddCorner(svPoint, 6)
            AddStroke(svPoint, Color3.fromRGB(0, 0, 0), 2, 0.3)
            
            local hueSlider = Create("Frame", {
                Name = "HueSlider",
                Size = UDim2.new(0, 18, 0, 90),
                Position = UDim2.new(1, -20, 0, 0),
                Parent = pickerArea,
            })
            AddCorner(hueSlider, 4)
            AddGradient(hueSlider, ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
                ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
                ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
                ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
                ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
                ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
            }), 90)
            
            local huePoint = Create("Frame", {
                Name = "HuePoint",
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(1, 4, 0, 6),
                Position = UDim2.new(-0.1, 0, h, -3),
                ZIndex = 5,
                Parent = hueSlider,
            })
            AddCorner(huePoint, 3)
            AddStroke(huePoint, Color3.fromRGB(0, 0, 0), 1, 0.3)
            
            local hexInput = Create("TextBox", {
                Name = "HexInput",
                BackgroundColor3 = theme.InputBackground,
                Size = UDim2.new(0.5, -4, 0, 22),
                Position = UDim2.new(0, 0, 0, 96),
                Text = string.format("#%02X%02X%02X", colorPickerSettings.Color.R * 255, colorPickerSettings.Color.G * 255, colorPickerSettings.Color.B * 255),
                TextColor3 = theme.TextPrimary,
                TextSize = 11,
                FontFace = theme.FontFace,
                ClearTextOnFocus = false,
                Parent = pickerArea,
            })
            AddCorner(hexInput, 4)
            AddStroke(hexInput, theme.InputBorder, 1, 0.5)
            
            local interact = Create("TextButton", {
                Name = "Interact",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 38),
                Text = "",
                ZIndex = 5,
                Parent = cpFrame,
            })
            
            interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    Tween(cpFrame, 0.35, { Size = UDim2.new(1, 0, 0, 175) })
                else
                    Tween(cpFrame, 0.35, { Size = UDim2.new(1, 0, 0, 38) })
                end
            end)
            
            local function updateColor()
                local color = Color3.fromHSV(h, s, v)
                colorPickerSettings.Color = color
                colorPreview.BackgroundColor3 = color
                svPicker.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svPoint.Position = UDim2.new(s, -6, 1 - v, -6)
                svPoint.BackgroundColor3 = color
                huePoint.Position = UDim2.new(-0.1, 0, h, -3)
                hexInput.Text = string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255)
                pcall(colorPickerSettings.Callback, color)
                SaveConfiguration()
            end
            
            local svDragging = false
            svPicker.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDragging = true
                end
            end)
            
            local hueDragging = false
            hueSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    hueDragging = true
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    svDragging = false
                    hueDragging = false
                end
            end)
            
            RunService.RenderStepped:Connect(function()
                if svDragging then
                    local relX = math.clamp((Mouse.X - svPicker.AbsolutePosition.X) / svPicker.AbsoluteSize.X, 0, 1)
                    local relY = math.clamp((Mouse.Y - svPicker.AbsolutePosition.Y) / svPicker.AbsoluteSize.Y, 0, 1)
                    s = relX
                    v = 1 - relY
                    updateColor()
                end
                if hueDragging then
                    local relY = math.clamp((Mouse.Y - hueSlider.AbsolutePosition.Y) / hueSlider.AbsoluteSize.Y, 0, 1)
                    h = relY
                    updateColor()
                end
            end)
            
            hexInput.FocusLost:Connect(function()
                pcall(function()
                    local hex = hexInput.Text:gsub("#", "")
                    local r = tonumber(hex:sub(1, 2), 16)
                    local g = tonumber(hex:sub(3, 4), 16)
                    local b = tonumber(hex:sub(5, 6), 16)
                    if r and g and b then
                        local newColor = Color3.fromRGB(r, g, b)
                        h, s, v = newColor:ToHSV()
                        updateColor()
                    end
                end)
            end)
            
            function colorPickerSettings:Set(newColor)
                h, s, v = newColor:ToHSV()
                colorPickerSettings.Color = newColor
                updateColor()
            end
            
            if colorPickerSettings.Flag then
                Exter.Flags[colorPickerSettings.Flag] = colorPickerSettings
            end
            
            return colorPickerSettings
        end
        
        return Tab
    end
    
    -- ═══════════════════════════════════════════════════════
    -- LOAD CONFIGURATION
    -- ═══════════════════════════════════════════════════════
    
    function Window:LoadConfiguration()
        if ConfigEnabled and ConfigFileName then
            pcall(function()
                local path = ConfigFolder .. "/" .. ConfigFileName .. ConfigExtension
                if isfile(path) then
                    LoadConfiguration(readfile(path))
                    Exter:Notify({
                        Title = "Configuration Loaded",
                        Content = "Your saved settings have been restored.",
                        Type = "Success",
                        Duration = 3,
                    })
                end
            end)
        end
    end
    
    -- Auto-load config after delay
    task.delay(2.5, function()
        Window:LoadConfiguration()
    end)
    
    return Window
end

-- ═══════════════════════════════════════════════════════════
-- DESTROY
-- ═══════════════════════════════════════════════════════════

function Exter:Destroy()
    if Exter.ScreenGui then
        Exter.ScreenGui:Destroy()
        Exter.ScreenGui = nil
    end
end

-- ═══════════════════════════════════════════════════════════
-- RETURN LIBRARY
-- ═══════════════════════════════════════════════════════════

return Exter


