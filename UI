    local theme = Exter.Theme
    
    if settings.Theme and Themes[settings.Theme] then
        Exter.Theme = Themes[settings.Theme]
        theme = Exter.Theme
    end
    
    -- Configuration
    if settings.ConfigurationSaving then
        ConfigEnabled = settings.ConfigurationSaving.Enabled or false
        ConfigFileName = settings.ConfigurationSaving.FileName or tostring(game.PlaceId)
        if ConfigEnabled then
            pcall(function()
                if not isfolder(LibraryFolder) then makefolder(LibraryFolder) end
                if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
            end)
        end
