            Create("TextLabel", {
                Name = "Title",
                BackgroundTransparency = 1,
                Size = UDim2.new(0.6, 0, 0, 20),
                Position = UDim2.new(0, 12, 0, 6),
                Text = sliderSettings.Name or "Slider",
                TextColor3 = theme.TextPrimary,
                TextSize = 13,
                FontFace = theme.FontFace,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = slider,
            })
            
            local valueLabel = Create("TextLabel", {
                Name = "Value",
                BackgroundColor3 = theme.Accent,
                BackgroundTransparency = 0.85,
                Size = UDim2.new(0, 50, 0, 18),
                Position = UDim2.new(1, -62, 0, 7),
                Text = tostring(sliderSettings.CurrentValue) .. (sliderSettings.Suffix and " " .. sliderSettings.Suffix or ""),
                TextColor3 = theme.Accent,
                TextSize = 11,
                FontFace = theme.FontFaceBold,
                Parent = slider,
            })
            AddCorner(valueLabel, 4)
            
            local sliderTrack = Create("Frame", {
                Name = "Track",
                BackgroundColor3 = theme.SliderBackground,
                Size = UDim2.new(1, -24, 0, 6),
                Position = UDim2.new(0, 12, 0, 34),
                Parent = slider,
            })
            AddCorner(sliderTrack, 3)
            
            local initialPercent = (sliderSettings.CurrentValue - range[1]) / (range[2] - range[1])
            local sliderFill = Create("Frame", {
                Name = "Fill",
                BackgroundColor3 = theme.SliderFill,
                Size = UDim2.new(math.clamp(initialPercent, 0, 1), 0, 1, 0),
                Parent = sliderTrack,
            })
            AddCorner(sliderFill, 3)
            AddGradient(sliderFill, ColorSequence.new({
                ColorSequenceKeypoint.new(0, theme.AccentDark),
                ColorSequenceKeypoint.new(1, theme.Accent),
            }))
            
            local sliderKnob = Create("Frame", {
                Name = "Knob",
                BackgroundColor3 = theme.SliderKnob,
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new(math.clamp(initialPercent, 0, 1), -7, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                ZIndex = 3,
                Parent = sliderTrack,
            })
            AddCorner(sliderKnob, 7)
            AddShadow(sliderKnob, 0.6, 6)
            
            local sliderDragging = false
            
            local interact = Create("TextButton", {
                Name = "Interact",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 10),
                Position = UDim2.new(0, 0, 0, -5),
                Text = "",
                ZIndex = 5,
                Parent = sliderTrack,
            })
            
            interact.MouseButton1Down:Connect(function()
                sliderDragging = true
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliderDragging = false
                end
            end)
            
            local function updateSlider(inputX)
                local trackPos = sliderTrack.AbsolutePosition.X
                local trackSize = sliderTrack.AbsoluteSize.X
                local relativeX = math.clamp((inputX - trackPos) / trackSize, 0, 1)
                
                local rawValue = range[1] + relativeX * (range[2] - range[1])
                local newValue = math.floor(rawValue / increment + 0.5) * increment
                newValue = math.clamp(newValue, range[1], range[2])
                newValue = tonumber(string.format("%.6f", newValue))
                
                local percent = (newValue - range[1]) / (range[2] - range[1])
                
                Tween(sliderFill, 0.1, { Size = UDim2.new(percent, 0, 1, 0) })
                Tween(sliderKnob, 0.1, { Position = UDim2.new(percent, -7, 0.5, 0) })
                
                valueLabel.Text = tostring(newValue) .. (sliderSettings.Suffix and " " .. sliderSettings.Suffix or "")
                
                if sliderSettings.CurrentValue ~= newValue then
                    sliderSettings.CurrentValue = newValue
                    pcall(sliderSettings.Callback, newValue)
                    SaveConfiguration()
                end
            end
            
            RunService.RenderStepped:Connect(function()
                if sliderDragging then
                    updateSlider(Mouse.X)
                end
            end)
            
            interact.MouseButton1Down:Connect(function()
                updateSlider(Mouse.X)
            end)
            
            slider.MouseEnter:Connect(function()
                Tween(slider, 0.25, { BackgroundColor3 = theme.ElementBackgroundHover })
            end)
            slider.MouseLeave:Connect(function()
                Tween(slider, 0.25, { BackgroundColor3 = theme.ElementBackground })
            end)
            
            function sliderSettings:Set(newValue)
                newValue = math.clamp(newValue, range[1], range[2])
                sliderSettings.CurrentValue = newValue
                local percent = (newValue - range[1]) / (range[2] - range[1])
                Tween(sliderFill, 0.3, { Size = UDim2.new(percent, 0, 1, 0) })
                Tween(sliderKnob, 0.3, { Position = UDim2.new(percent, -7, 0.5, 0) })
                valueLabel.Text = tostring(newValue) .. (sliderSettings.Suffix and " " .. sliderSettings.Suffix or "")
                pcall(sliderSettings.Callback, newValue)
                SaveConfiguration()
            end
            
            if sliderSettings.Flag then
                Exter.Flags[sliderSettings.Flag] = sliderSettings
            end
            
            return sliderSettings
        end
        
