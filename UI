    AddPadding(tabListScroll, 4, 4, 4, 4)
    
    -- ═══════════════════════════════════════════════════════
    -- CONTENT AREA
    -- ═══════════════════════════════════════════════════════
    
    local contentArea = Create("Frame", {
        Name = "Content",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -141, 1, -43),
        Position = UDim2.new(0, 141, 0, 43),
        ClipsDescendants = true,
        Parent = mainFrame,
    })
    
    -- ═══════════════════════════════════════════════════════
    -- NOTIFICATION CONTAINER
    -- ═══════════════════════════════════════════════════════
    
    NotificationContainer = Create("Frame", {
        Name = "Notifications",
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 300, 0, 400),
        Position = UDim2.new(1, -310, 1, -410),
        Parent = screenGui,
    })
    AddListLayout(NotificationContainer, 6, Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Bottom)
    
    -- ═══════════════════════════════════════════════════════
    -- WINDOW STATE MANAGEMENT
    -- ═══════════════════════════════════════════════════════
    
    local isMinimized = false
    local isHidden = false
    local originalSize = UDim2.new(0, 550, 0, 380)
    
    minimizeBtn.MouseButton1Click:Connect(function()
        if isMinimized then
            isMinimized = false
            minimizeBtn.Text = "─"
            Tween(mainFrame, 0.4, { Size = originalSize })
            task.delay(0.15, function()
                sidebar.Visible = true
                contentArea.Visible = true
                Tween(sidebar, 0.3, { BackgroundTransparency = 0 })
            end)
        else
            isMinimized = true
            minimizeBtn.Text = "□"
            Tween(sidebar, 0.2, { BackgroundTransparency = 1 })
            task.delay(0.1, function()
                sidebar.Visible = false
                contentArea.Visible = false
            end)
            Tween(mainFrame, 0.4, { Size = UDim2.new(0, 550, 0, 42) })
        end
    end)
    
    hideBtn.MouseButton1Click:Connect(function()
        isHidden = true
        Tween(mainFrame, 0.35, { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 })
        task.delay(0.4, function()
            mainFrame.Visible = false
        end)
    end)
    
    -- Toggle key
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Exter.ToggleKey then
            if isHidden then
                isHidden = false
                mainFrame.Visible = true
                mainFrame.Size = UDim2.new(0, 0, 0, 0)
                mainFrame.BackgroundTransparency = 1
                if isMinimized then
                    Tween(mainFrame, 0.4, { Size = UDim2.new(0, 550, 0, 42), BackgroundTransparency = 0 })
                else
                    Tween(mainFrame, 0.4, { Size = originalSize, BackgroundTransparency = 0 })
                end
            else
                isHidden = true
                Tween(mainFrame, 0.35, { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 })
                task.delay(0.4, function()
                    mainFrame.Visible = false
                end)
            end
        end
    end)
    
    -- Theme cycling
    local themeOrder = { "Dark", "Light", "Neon", "Ocean", "Sunset" }
    local currentThemeIndex = 1
    for i, name in ipairs(themeOrder) do
        if name == (settings.Theme or "Dark") then
            currentThemeIndex = i
            break
        end
    end
    
    themeBtn.MouseButton1Click:Connect(function()
        currentThemeIndex = currentThemeIndex % #themeOrder + 1
        local newThemeName = themeOrder[currentThemeIndex]
        ApplyTheme(newThemeName)
        Exter:Notify({
            Title = "Theme Changed",
            Content = "Switched to " .. newThemeName .. " theme",
            Type = "Info",
            Duration = 2,
        })
    end)
    
    -- ═══════════════════════════════════════════════════════
    -- LOADING ANIMATION
    -- ═══════════════════════════════════════════════════════
    
    local loadingFrame = Create("Frame", {
        Name = "Loading",
