        BackgroundTransparency = 1,
        Size = UDim2.new(0, 24, 0, 24),
        Position = UDim2.new(1, -30, 0, 10),
        Text = "×",
        TextColor3 = theme.TextMuted,
        TextSize = 18,
        FontFace = theme.FontFaceBold,
        Parent = notif,
    })
    
    -- Progress bar
    local progressBg = Create("Frame", {
        Name = "ProgressBg",
        BackgroundColor3 = theme.ElementBorder,
        BackgroundTransparency = 0.5,
        Size = UDim2.new(1, -16, 0, 2),
        Position = UDim2.new(0, 8, 1, -6),
        Parent = notif,
    })
    AddCorner(progressBg, 1)
    
    local progressFill = Create("Frame", {
        Name = "ProgressFill",
        BackgroundColor3 = accentColor,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = progressBg,
    })
    AddCorner(progressFill, 1)
    
    -- Action buttons
    local hasActions = settings.Actions and #settings.Actions > 0
    local actionContainer
    if hasActions then
        actionContainer = Create("Frame", {
            Name = "Actions",
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -60, 0, 30),
            Position = UDim2.new(0, 54, 0, 62),
            Parent = notif,
        })
        AddListLayout(actionContainer, 6, Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Left)
        
        for _, action in ipairs(settings.Actions) do
            local actionBtn = Create("TextButton", {
                Name = action.Name,
                BackgroundColor3 = accentColor,
                BackgroundTransparency = 0.8,
                Size = UDim2.new(0, 80, 0, 26),
                Text = action.Name,
                TextColor3 = accentColor,
                TextSize = 11,
                FontFace = theme.FontFaceBold,
                AutoButtonColor = false,
                Parent = actionContainer,
            })
            AddCorner(actionBtn, 6)
            AddStroke(actionBtn, accentColor, 1, 0.7)
            
            actionBtn.MouseEnter:Connect(function()
                Tween(actionBtn, 0.2, { BackgroundTransparency = 0.6 })
            end)
            actionBtn.MouseLeave:Connect(function()
                Tween(actionBtn, 0.2, { BackgroundTransparency = 0.8 })
            end)
            actionBtn.MouseButton1Click:Connect(function()
                pcall(action.Callback)
            end)
        end
    end
    
    -- Animate in
    local targetHeight = hasActions and 100 or 70
    notif.Size = UDim2.new(1, 0, 0, 0)
    Tween(notif, 0.4, { Size = UDim2.new(1, 0, 0, targetHeight) })
    
    -- Progress animation
    Tween(progressFill, duration, { Size = UDim2.new(0, 0, 1, 0) }, Enum.EasingStyle.Linear)
    
    -- Close function
    local closed = false
    local function closeNotif()
        if closed then return end
        closed = true
        Tween(notif, 0.3, { Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1 })
        task.delay(0.35, function()
            notif:Destroy()
        end)
    end
    
    closeBtn.MouseButton1Click:Connect(closeNotif)
    task.delay(duration, closeNotif)
end

