                Text = tabIcon, TextSize = 15, Parent = tabBtn })
        end

        local tabTitle = Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
            Size = UDim2.new(1, tabIcon and -44 or -20, 1, 0),
            Position = UDim2.new(0, tabIcon and 36 or 12, 0, 0),
            Text = tabName, TextColor3 = theme.TabText, TextSize = 13,
