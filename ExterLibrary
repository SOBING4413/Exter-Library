    Create("Frame", { Name = "Divider", BackgroundColor3 = theme.DividerColor,
        Size = UDim2.new(0, 1, 1, 0), Position = UDim2.new(1, 0, 0, 0),
        BorderSizePixel = 0, Parent = sidebar })

    local userSection = Create("Frame", { Name = "UserSection", BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 0.9, Size = UDim2.new(1, -12, 0, 55),
