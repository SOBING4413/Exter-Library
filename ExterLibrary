        BorderSizePixel = 0, Parent = sidebar })

    -- User info section
    local userSection = Create("Frame", { Name = "UserSection", BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 0.9, Size = UDim2.new(1, -12, 0, 50),
        Position = UDim2.new(0, 6, 0, 6), Parent = sidebar })
    AddCorner(userSection, 10)

    local userAvatar = Create("Frame", { Name = "Avatar", BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 0.7, Size = UDim2.new(0, 32, 0, 32),
        Position = UDim2.new(0, 8, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Parent = userSection })
    AddCorner(userAvatar, 999)
    Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0),
        Text = string.sub(Player.Name, 1, 1):upper(), TextColor3 = theme.Accent,
        TextSize = 14, FontFace = theme.FontFaceBold, Parent = userAvatar })
    Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -52, 0, 16),
        Position = UDim2.new(0, 46, 0, 10), Text = Player.Name, TextColor3 = theme.TextPrimary,
        TextSize = 12, FontFace = theme.FontFaceBold, TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd, Parent = userSection })
    Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -52, 0, 14),
        Position = UDim2.new(0, 46, 0, 26), Text = "Premium User", TextColor3 = theme.Success,
        TextSize = 10, FontFace = theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
        Parent = userSection })

    local tabListScroll = Create("ScrollingFrame", { Name = "TabList", BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 1, -68), Position = UDim2.new(0, 4, 0, 62),
        ScrollBarThickness = 2, ScrollBarImageColor3 = theme.ScrollbarColor,
        ScrollBarImageTransparency = 0.4, CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y, BorderSizePixel = 0, Parent = sidebar })
    AddListLayout(tabListScroll, 3)
    AddPadding(tabListScroll, 4, 4, 4, 4)

    -- Content Area
    local contentArea = Create("Frame", { Name = "Content", BackgroundTransparency = 1,
        Size = UDim2.new(1, -151, 1, -48), Position = UDim2.new(0, 151, 0, 48),
        ClipsDescendants = true, Parent = mainFrame })

    -- Notification Container
    NotificationContainer = Create("Frame", { Name = "Notifications", BackgroundTransparency = 1,
        Size = UDim2.new(0, 320, 0, 420), Position = UDim2.new(1, -330, 1, -430),
        Parent = screenGui })
    AddListLayout(NotificationContainer, 8, Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Bottom)

    -- Window state
    local isMinimized = false
    local isHidden = false
    local originalSize = UDim2.new(0, 580, 0, 400)

    minimizeBtn.MouseButton1Click:Connect(function()
        if isMinimized then
            isMinimized = false
            minimizeBtn.Text = "-"
            Tween(mainFrame, 0.45, { Size = originalSize })
            task.delay(0.15, function()
                sidebar.Visible = true
                contentArea.Visible = true
            end)
        else
            isMinimized = true
            minimizeBtn.Text = "+"
            task.delay(0.1, function() sidebar.Visible = false; contentArea.Visible = false end)
            Tween(mainFrame, 0.45, { Size = UDim2.new(0, 580, 0, 48) })
        end
    end)

    hideBtn.MouseButton1Click:Connect(function()
        isHidden = true
        Tween(mainFrame, 0.4, { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 })
        task.delay(0.45, function() mainFrame.Visible = false end)
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Exter.ToggleKey then
            if isHidden then
                isHidden = false
                mainFrame.Visible = true
                mainFrame.Size = UDim2.new(0, 0, 0, 0)
                mainFrame.BackgroundTransparency = 1
                if isMinimized then
                    Tween(mainFrame, 0.45, { Size = UDim2.new(0, 580, 0, 48), BackgroundTransparency = 0 })
