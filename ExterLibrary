            TextTruncate = Enum.TextTruncate.AtEnd, Parent = tabBtn })

        local activeIndicator = Create("Frame", { Name = "ActiveIndicator",
            BackgroundColor3 = theme.Accent, Size = UDim2.new(0, 3, 0, 0),
            Position = UDim2.new(0, 0, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Parent = tabBtn })
        AddCorner(activeIndicator, 2)

