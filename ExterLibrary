function Exter:CreateWindow(settings)
    local theme = Exter.Theme
    if settings.Theme and Themes[settings.Theme] then
        Exter.Theme = Themes[settings.Theme]
        theme = Exter.Theme
    end

    if settings.ConfigurationSaving then
        ConfigEnabled = settings.ConfigurationSaving.Enabled or false
        ConfigFileName = settings.ConfigurationSaving.FileName or tostring(game.PlaceId)
        if ConfigEnabled then
            pcall(function()
                if not isfolder(LibraryFolder) then makefolder(LibraryFolder) end
                if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
            end)
        end
    end

    if settings.ToggleKey then Exter.ToggleKey = settings.ToggleKey end

    local screenGui = Create("ScreenGui", { Name = "ExterLib",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling, ResetOnSpawn = false, DisplayOrder = 120 })
    pcall(function()
        if gethui then screenGui.Parent = gethui()
        elseif syn and syn.protect_gui then syn.protect_gui(screenGui); screenGui.Parent = CoreGui
        else screenGui.Parent = CoreGui end
    end)

    local parentContainer = screenGui.Parent
    if parentContainer then
        for _, child in ipairs(parentContainer:GetChildren()) do
            if child.Name == "ExterLib" and child ~= screenGui then child:Destroy() end
        end
    end
    Exter.ScreenGui = screenGui

    CreateFullscreenLoadingScreen(screenGui, settings, theme)

    local responsiveScale, viewport = EvaluateResponsiveScale()
    local layout = BuildWindowLayoutPresets(viewport)

    local gameplayFriendly = settings.GameplayFriendly ~= false
    local backdropEffectsEnabled = settings.EnableBackgroundEffects == true
    local windowTransparency = gameplayFriendly and math.max(theme.WindowTransparency or 0.08, 0.2) or (theme.WindowTransparency or 0.08)
    local topbarTransparency = gameplayFriendly and math.max(theme.TopbarTransparency or 0.05, 0.2) or (theme.TopbarTransparency or 0.05)
    local sidebarTransparency = gameplayFriendly and math.max(theme.SidebarTransparency or 0.1, 0.24) or (theme.SidebarTransparency or 0.1)

    local backdropDim = CreateBackdropLayer(screenGui, theme)
    local orbLayer = CreateAmbientOrbs(screenGui, theme)
    if backdropEffectsEnabled and not gameplayFriendly then
        backdropDim.Visible = true
        backdropDim.BackgroundTransparency = theme.BackdropTransparency or 0.24
        local noise = backdropDim:FindFirstChild("Noise")
        if noise and noise:IsA("ImageLabel") then
            noise.ImageTransparency = 0.92
        end
        local vignette = backdropDim:FindFirstChild("Vignette")
        if vignette and vignette:IsA("ImageLabel") then
            vignette.ImageTransparency = 0.62
        end
        orbLayer.Visible = true
    end

