        BorderSizePixel = 0, Parent = mainFrame })
    AddGradient(sidebar, ColorSequence.new({
        ColorSequenceKeypoint.new(0, LerpColor(theme.BackgroundSecondary, theme.Accent, 0.16)),
        ColorSequenceKeypoint.new(1, theme.BackgroundSecondary),
