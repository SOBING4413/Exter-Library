local function LerpColor(c1, c2, t)
    return Color3.new(c1.R + (c2.R - c1.R) * t, c1.G + (c2.G - c1.G) * t, c1.B + (c2.B - c1.B) * t)
end

local function PackColor(color)
    return { R = math.floor(color.R * 255), G = math.floor(color.G * 255), B = math.floor(color.B * 255) }
end

local function UnpackColor(data)
    return Color3.fromRGB(data.R, data.G, data.B)
end

local function RippleEffect(button, x, y)
    local ripple = Create("Frame", {
        Name = "Ripple", AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.65,
        Position = UDim2.new(0, x - button.AbsolutePosition.X, 0, y - button.AbsolutePosition.Y),
        Size = UDim2.new(0, 0, 0, 0), ZIndex = 10, Parent = button,
    })
    AddCorner(ripple, 999)
    local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.5
    Tween(ripple, 0.55, { Size = UDim2.new(0, maxSize, 0, maxSize), BackgroundTransparency = 1 })
    task.delay(0.55, function() ripple:Destroy() end)
end

-- ═══════════════════════════════════════════════════════════
-- CONFIGURATION SAVING
-- ═══════════════════════════════════════════════════════════

local ConfigEnabled = false
local ConfigFileName = nil

local function SaveConfiguration()
    if not ConfigEnabled or not ConfigFileName then return end
    local data = {}
    for flagName, flagData in pairs(Exter.Flags) do
        if flagData.Type == "ColorPicker" then data[flagName] = PackColor(flagData.Color)
        elseif flagData.Type == "Toggle" then data[flagName] = flagData.CurrentValue
        elseif flagData.Type == "Slider" then data[flagName] = flagData.CurrentValue
        elseif flagData.Type == "Dropdown" then data[flagName] = flagData.CurrentOption
        elseif flagData.Type == "Input" then data[flagName] = flagData.CurrentValue
        elseif flagData.Type == "Keybind" then data[flagName] = flagData.CurrentKeybind
        end
    end
    pcall(function()
        if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
        writefile(ConfigFolder .. "/" .. ConfigFileName .. ConfigExtension, HttpService:JSONEncode(data))
    end)
end

local function LoadConfiguration(configString)
    local success, data = pcall(HttpService.JSONDecode, HttpService, configString)
    if not success then return end
    for flagName, flagValue in pairs(data) do
        if Exter.Flags[flagName] then
            task.spawn(function()
                if Exter.Flags[flagName].Type == "ColorPicker" then
                    Exter.Flags[flagName]:Set(UnpackColor(flagValue))
                else
                    Exter.Flags[flagName]:Set(flagValue)
                end
            end)
        end
    end
end

-- ═══════════════════════════════════════════════════════════
-- DRAGGING SYSTEM
-- ═══════════════════════════════════════════════════════════

local function MakeDraggable(dragHandle, targetFrame)
    local dragging = false
    local dragStart, startPos
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = targetFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            Tween(targetFrame, 0.12, {
                Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            }, Enum.EasingStyle.Quart)
        end
    end)
end

