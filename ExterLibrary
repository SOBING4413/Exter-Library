        function Tab:CreateKeybind(keybindSettings)
            keybindSettings.Type = "Keybind"
            keybindSettings.CurrentKeybind = keybindSettings.CurrentKeybind or "E"
            local keybind = Create("Frame", { Name = "Keybind_" .. (keybindSettings.Name or "Keybind"),
                BackgroundColor3 = theme.ElementBackground, BackgroundTransparency = 0.15,
                Size = UDim2.new(1, 0, 0, 40), Parent = tabPage })
            AddCorner(keybind, 10)
            AddStroke(keybind, theme.ElementBorder, 1, 0.3)
            Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
                Size = UDim2.new(0.6, 0, 1, 0), Position = UDim2.new(0, 14, 0, 0),
                Text = keybindSettings.Name or "Keybind", TextColor3 = theme.TextPrimary,
                TextSize = 13, FontFace = theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = keybind })
            local keybindBox = Create("TextButton", { Name = "KeyBox", BackgroundColor3 = theme.InputBackground,
                Size = UDim2.new(0, 65, 0, 28), Position = UDim2.new(1, -77, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5), Text = keybindSettings.CurrentKeybind,
                TextColor3 = theme.Accent, TextSize = 12, FontFace = theme.FontFaceBold,
                AutoButtonColor = false, Parent = keybind })
            AddCorner(keybindBox, 8)
            AddStroke(keybindBox, theme.InputBorder, 1, 0.3)

            local listening = false
            keybindBox.MouseButton1Click:Connect(function()
                listening = true
                keybindBox.Text = "..."
                Tween(keybindBox.UIStroke, 0.2, { Color = theme.Accent })
            end)
            UserInputService.InputBegan:Connect(function(input, processed)
                if listening then
                    if input.KeyCode ~= Enum.KeyCode.Unknown then
                        keybindSettings.CurrentKeybind = input.KeyCode.Name
                        keybindBox.Text = input.KeyCode.Name
                        listening = false
                        Tween(keybindBox.UIStroke, 0.2, { Color = theme.InputBorder })
                        SaveConfiguration()
                    end
                elseif not processed and keybindSettings.CurrentKeybind then
                    if input.KeyCode == Enum.KeyCode[keybindSettings.CurrentKeybind] then
                        pcall(keybindSettings.Callback)
                    end
                end
            end)
            keybind.MouseEnter:Connect(function()
                Tween(keybind, 0.25, { BackgroundColor3 = theme.ElementBackgroundHover, BackgroundTransparency = 0.05 })
            end)
            keybind.MouseLeave:Connect(function()
                Tween(keybind, 0.25, { BackgroundColor3 = theme.ElementBackground, BackgroundTransparency = 0.15 })
            end)
            function keybindSettings:Set(newKey)
                keybindSettings.CurrentKeybind = newKey; keybindBox.Text = newKey; SaveConfiguration()
            end
            if keybindSettings.Flag then Exter.Flags[keybindSettings.Flag] = keybindSettings end
            return keybindSettings
        end

        -- ColorPicker
        function Tab:CreateColorPicker(cpSettings)
            cpSettings.Type = "ColorPicker"
            cpSettings.Color = cpSettings.Color or Color3.fromRGB(255, 255, 255)
            local isOpen = false
            local h, s, v = cpSettings.Color:ToHSV()

            local cpFrame = Create("Frame", { Name = "ColorPicker_" .. (cpSettings.Name or "ColorPicker"),
                BackgroundColor3 = theme.ElementBackground, BackgroundTransparency = 0.15,
                Size = UDim2.new(1, 0, 0, 40), ClipsDescendants = true, Parent = tabPage })
            AddCorner(cpFrame, 10)
            AddStroke(cpFrame, theme.ElementBorder, 1, 0.3)
            Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
                Size = UDim2.new(0.6, 0, 0, 40), Position = UDim2.new(0, 14, 0, 0),
                Text = cpSettings.Name or "Color Picker", TextColor3 = theme.TextPrimary,
                TextSize = 13, FontFace = theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = cpFrame })
            local colorPreview = Create("Frame", { Name = "Preview", BackgroundColor3 = cpSettings.Color,
                Size = UDim2.new(0, 30, 0, 24), Position = UDim2.new(1, -42, 0, 8), Parent = cpFrame })
            AddCorner(colorPreview, 8)
            AddStroke(colorPreview, theme.ElementBorder, 1, 0.3)

            local pickerArea = Create("Frame", { Name = "PickerArea", BackgroundTransparency = 1,
                Size = UDim2.new(1, -16, 0, 120), Position = UDim2.new(0, 8, 0, 46), Parent = cpFrame })
            local svPicker = Create("ImageLabel", { Name = "SVPicker",
                BackgroundColor3 = Color3.fromHSV(h, 1, 1), Size = UDim2.new(1, -30, 0, 90),
                Image = "rbxassetid://11415645739", Parent = pickerArea })
            AddCorner(svPicker, 6)
            local svPoint = Create("Frame", { Name = "Point", BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(s, -6, 1 - v, -6),
                ZIndex = 5, Parent = svPicker })
            AddCorner(svPoint, 6)
            AddStroke(svPoint, Color3.fromRGB(0, 0, 0), 2, 0.3)

            local hueSlider = Create("Frame", { Name = "HueSlider", Size = UDim2.new(0, 18, 0, 90),
                Position = UDim2.new(1, -20, 0, 0), Parent = pickerArea })
            AddCorner(hueSlider, 4)
            AddGradient(hueSlider, ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
                ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
                ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
                ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
                ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
                ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
            }), 90)
            local huePoint = Create("Frame", { Name = "HuePoint", BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(1, 4, 0, 6), Position = UDim2.new(-0.1, 0, h, -3),
                ZIndex = 5, Parent = hueSlider })
            AddCorner(huePoint, 3)
            AddStroke(huePoint, Color3.fromRGB(0, 0, 0), 1, 0.3)

            local hexInput = Create("TextBox", { Name = "HexInput", BackgroundColor3 = theme.InputBackground,
                Size = UDim2.new(0.5, -4, 0, 22), Position = UDim2.new(0, 0, 0, 96),
                Text = string.format("#%02X%02X%02X", cpSettings.Color.R * 255, cpSettings.Color.G * 255, cpSettings.Color.B * 255),
                TextColor3 = theme.TextPrimary, TextSize = 11, FontFace = theme.FontFace,
                ClearTextOnFocus = false, Parent = pickerArea })
            AddCorner(hexInput, 4)
            AddStroke(hexInput, theme.InputBorder, 1, 0.5)

            local interact = Create("TextButton", { Name = "Interact", BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 40), Text = "", ZIndex = 5, Parent = cpFrame })
            interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(cpFrame, 0.35, { Size = UDim2.new(1, 0, 0, isOpen and 178 or 40) })
            end)

            local function updateColor()
                local color = Color3.fromHSV(h, s, v)
                cpSettings.Color = color
                colorPreview.BackgroundColor3 = color
                svPicker.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svPoint.Position = UDim2.new(s, -6, 1 - v, -6)
                svPoint.BackgroundColor3 = color
                huePoint.Position = UDim2.new(-0.1, 0, h, -3)
                hexInput.Text = string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255)
                pcall(cpSettings.Callback, color); SaveConfiguration()
            end

            local svDragging, hueDragging = false, false
            svPicker.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = true end
            end)
            hueSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = false; hueDragging = false end
            end)
            RunService.RenderStepped:Connect(function()
                if svDragging then
                    s = math.clamp((Mouse.X - svPicker.AbsolutePosition.X) / svPicker.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp((Mouse.Y - svPicker.AbsolutePosition.Y) / svPicker.AbsoluteSize.Y, 0, 1)
                    updateColor()
                end
                if hueDragging then
                    h = math.clamp((Mouse.Y - hueSlider.AbsolutePosition.Y) / hueSlider.AbsoluteSize.Y, 0, 1)
                    updateColor()
                end
            end)
            hexInput.FocusLost:Connect(function()
                pcall(function()
                    local hex = hexInput.Text:gsub("#", "")
                    local r = tonumber(hex:sub(1, 2), 16)
                    local g = tonumber(hex:sub(3, 4), 16)
                    local b = tonumber(hex:sub(5, 6), 16)
                    if r and g and b then h, s, v = Color3.fromRGB(r, g, b):ToHSV(); updateColor() end
                end)
            end)
            function cpSettings:Set(newColor) h, s, v = newColor:ToHSV(); cpSettings.Color = newColor; updateColor() end
            if cpSettings.Flag then Exter.Flags[cpSettings.Flag] = cpSettings end
            return cpSettings
        end

        return Tab
    end

    -- Load Configuration
    function Window:LoadConfiguration()
        if ConfigEnabled and ConfigFileName then
            pcall(function()
                local path = ConfigFolder .. "/" .. ConfigFileName .. ConfigExtension
                if isfile(path) then
                    LoadConfiguration(readfile(path))
                    Exter:Notify({ Title = "Config Loaded", Content = "Settings restored.", Type = "Success", Duration = 3 })
                end
            end)
        end
    end

    task.delay(2.5, function() Window:LoadConfiguration() end)
    return Window
end

function Exter:Destroy()
    if Exter.ScreenGui then Exter.ScreenGui:Destroy(); Exter.ScreenGui = nil end
end

return Exter
