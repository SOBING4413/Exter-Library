-- RESPONSIVE & GLASS HELPERS
-- ═══════════════════════════════════════════════════════════

local function GetViewportSize()
    local cam = workspace.CurrentCamera
    if cam and cam.ViewportSize then
        return cam.ViewportSize
    end
    return Vector2.new(1920, 1080)
end

local function EvaluateResponsiveScale()
    local viewport = GetViewportSize()
    local shortest = math.max(480, math.min(viewport.X, viewport.Y))
    local scale = shortest / 900
    -- Keep menu compact so it does not dominate gameplay on bigger screens.
    return math.clamp(scale, 0.72, 1), viewport
end

local function BuildWindowLayoutPresets(viewport)
    -- Gameplay-first layout: smaller by default and easier to keep out of view.
    local width = math.clamp(math.floor(viewport.X * 0.46), 480, 760)
    local height = math.clamp(math.floor(viewport.Y * 0.54), 320, 560)
    local compact = viewport.X <= 860 or viewport.Y <= 560
    local sidebarWidth = compact and 120 or math.clamp(math.floor(width * 0.28), 132, 185)
    local topbarHeight = compact and 42 or 46

    return {
        MainSize = UDim2.fromOffset(width, height),
        MinimizedSize = UDim2.fromOffset(width, topbarHeight),
        SidebarWidth = sidebarWidth,
        TopbarHeight = topbarHeight,
        Compact = compact,
        NotificationWidth = compact and 300 or 360,
        NotificationHeight = compact and 360 or 450,
    }
end

local function CreateBackdropLayer(parent, theme)
    local dim = Create("Frame", {
        Name = "BackdropDim",
        BackgroundColor3 = Color3.fromRGB(5, 6, 11),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
