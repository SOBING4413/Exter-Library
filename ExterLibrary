    AddCorner(userSection, 10)
    AddGradient(userSection, ColorSequence.new({
        ColorSequenceKeypoint.new(0, LerpColor(theme.Accent, theme.GradientAccent1, 0.2)),
        ColorSequenceKeypoint.new(1, LerpColor(theme.Accent, theme.GradientAccent2, 0.3)),
    }), 30)

    local userAvatar = Create("Frame", { Name = "Avatar", BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 0.7, Size = UDim2.new(0, 36, 0, 36),
        Position = UDim2.new(0, 8, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Parent = userSection })
    AddCorner(userAvatar, 999)
    Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0),
        Text = string.sub(Player.Name, 1, 1):upper(), TextColor3 = theme.Accent,
        TextSize = 16, FontFace = theme.FontFaceBold, Parent = userAvatar })
    Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -56, 0, 18),
        Position = UDim2.new(0, 50, 0, 8), Text = Player.Name, TextColor3 = theme.TextPrimary,
        TextSize = 13, FontFace = theme.FontFaceBold, TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd, Parent = userSection })
    Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -56, 0, 16),
        Position = UDim2.new(0, 50, 0, 28), Text = "Premium User", TextColor3 = theme.Success,
        TextSize = 11, FontFace = theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
        Parent = userSection })

    local tabListScroll = Create("ScrollingFrame", { Name = "TabList", BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 1, -(layout.Compact and 69 or 73)), Position = UDim2.new(0, 4, 0, layout.Compact and 63 or 67),
        ScrollBarThickness = 2, ScrollBarImageColor3 = theme.ScrollbarColor,
        ScrollBarImageTransparency = 0.4, CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y, BorderSizePixel = 0, Parent = sidebar })
    AddListLayout(tabListScroll, 3)
    AddPadding(tabListScroll, 4, 4, 4, 4)

    local contentArea = Create("Frame", { Name = "Content", BackgroundTransparency = 1,
        Size = UDim2.new(1, -(layout.SidebarWidth + 1), 1, -layout.TopbarHeight), Position = UDim2.new(0, layout.SidebarWidth, 0, layout.TopbarHeight),
        ClipsDescendants = true, Parent = mainFrame })

    NotificationContainer = Create("Frame", { Name = "Notifications", BackgroundTransparency = 1,
        Size = UDim2.fromOffset(layout.NotificationWidth, layout.NotificationHeight),
        Position = UDim2.new(1, -(layout.NotificationWidth + 10), 1, -(layout.NotificationHeight + 10)),
        Parent = screenGui })
    AddListLayout(NotificationContainer, 8, Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Bottom)

    local isMinimized = false
    local isHidden = false
    local originalSize = layout.MainSize

    minimizeBtn.MouseButton1Click:Connect(function()
        if isMinimized then
            isMinimized = false
            minimizeBtn.Text = "_"
            Tween(mainFrame, 0.45, { Size = originalSize })
            task.delay(0.15, function()
                sidebar.Visible = true
                contentArea.Visible = true
            end)
        else
            isMinimized = true
            minimizeBtn.Text = "□"
            sidebar.Visible = false
            contentArea.Visible = false
            Tween(mainFrame, 0.45, { Size = layout.MinimizedSize })
        end
    end)

    hideBtn.MouseButton1Click:Connect(function()
        isHidden = true
        Tween(mainFrame, 0.4, { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 })
        task.delay(0.45, function() mainFrame.Visible = false end)
    end)

    TrackConnection(UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == Exter.ToggleKey then
            if isHidden then
                isHidden = false
                mainFrame.Visible = true
                mainFrame.Size = UDim2.new(0, 0, 0, 0)
                mainFrame.BackgroundTransparency = 1
                if isMinimized then
                    Tween(mainFrame, 0.45, { Size = layout.MinimizedSize, BackgroundTransparency = windowTransparency })
                else
                    Tween(mainFrame, 0.45, { Size = originalSize, BackgroundTransparency = windowTransparency })
                end
            else
                isHidden = true
                Tween(mainFrame, 0.4, { Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1 })
                task.delay(0.45, function() mainFrame.Visible = false end)
            end
        end
    end))

    local uiScale = Create("UIScale", {
        Name = "AdaptiveScale",
        Scale = responsiveScale,
        Parent = mainFrame,
    })

    local function ReflowResponsiveLayout()
        local latestScale, latestViewport = EvaluateResponsiveScale()
        responsiveScale = latestScale
        uiScale.Scale = responsiveScale
        layout = BuildWindowLayoutPresets(latestViewport)
        if not isMinimized then
            originalSize = layout.MainSize
            mainFrame.Size = originalSize
        else
            mainFrame.Size = layout.MinimizedSize
        end

        topbar.Size = UDim2.new(1, 0, 0, layout.TopbarHeight)
        sidebar.Size = UDim2.new(0, layout.SidebarWidth, 1, -layout.TopbarHeight)
        sidebar.Position = UDim2.new(0, 0, 0, layout.TopbarHeight)
        contentArea.Size = UDim2.new(1, -(layout.SidebarWidth + 1), 1, -layout.TopbarHeight)
        contentArea.Position = UDim2.new(0, layout.SidebarWidth, 0, layout.TopbarHeight)

        NotificationContainer.Size = UDim2.fromOffset(layout.NotificationWidth, layout.NotificationHeight)
        NotificationContainer.Position = UDim2.new(1, -(layout.NotificationWidth + 10), 1, -(layout.NotificationHeight + 10))

        versionBadge.Visible = not layout.Compact
        topbarButtons.Size = UDim2.new(0, layout.Compact and 126 or 140, 0, layout.TopbarHeight)
        topbarButtons.Position = UDim2.new(1, layout.Compact and -134 or -150, 0, 0)
    end

    TrackConnection(screenGui:GetPropertyChangedSignal("AbsoluteSize"):Connect(ReflowResponsiveLayout))

    local themeOrder = { "Dark", "Neon", "Ocean", "Sunset", "Cyberpunk", "Aurora", "Ruby", "Frost", "Monochrome" }
    local currentThemeIndex = 1
    for i, name in ipairs(themeOrder) do
        if name == (settings.Theme or "Dark") then currentThemeIndex = i; break end
    end

    local function ApplyThemeToUI(themeName)
        if not Themes[themeName] then return end
        local oldTheme = Exter.Theme
        local newTheme = Themes[themeName]
        Exter.Theme = newTheme
        windowTransparency = gameplayFriendly and math.max(newTheme.WindowTransparency or 0.08, 0.2) or (newTheme.WindowTransparency or 0.08)
        topbarTransparency = gameplayFriendly and math.max(newTheme.TopbarTransparency or 0.05, 0.2) or (newTheme.TopbarTransparency or 0.05)
        sidebarTransparency = gameplayFriendly and math.max(newTheme.SidebarTransparency or 0.1, 0.24) or (newTheme.SidebarTransparency or 0.1)

        local lookup = BuildThemeColorLookup(oldTheme)
        local roots = { screenGui }
        if NotificationContainer then
            table.insert(roots, NotificationContainer)
        end

        for _, root in ipairs(roots) do
            for _, instance in ipairs(root:GetDescendants()) do
                if instance:IsA("Frame") or instance:IsA("TextButton") or instance:IsA("TextLabel") or instance:IsA("ImageLabel") or instance:IsA("ImageButton") or instance:IsA("ScrollingFrame") then
                    if instance.BackgroundTransparency < 1 then
                        instance.BackgroundColor3 = MapThemeColor(instance.BackgroundColor3, oldTheme, newTheme, lookup)
                    end
                end
                if instance:IsA("TextLabel") or instance:IsA("TextButton") or instance:IsA("TextBox") then
                    instance.TextColor3 = MapThemeColor(instance.TextColor3, oldTheme, newTheme, lookup)
                    if instance:IsA("TextBox") then
                        instance.PlaceholderColor3 = MapThemeColor(instance.PlaceholderColor3, oldTheme, newTheme, lookup)
                    end
                elseif instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
                    instance.ImageColor3 = MapThemeColor(instance.ImageColor3, oldTheme, newTheme, lookup)
                elseif instance:IsA("UIStroke") then
                    instance.Color = MapThemeColor(instance.Color, oldTheme, newTheme, lookup)
                elseif instance:IsA("ScrollingFrame") then
                    instance.ScrollBarImageColor3 = MapThemeColor(instance.ScrollBarImageColor3, oldTheme, newTheme, lookup)
                elseif instance:IsA("UIGradient") then
                    MapThemeGradient(instance, oldTheme, newTheme, lookup)
                end
            end
        end

        mainFrame.BackgroundColor3 = newTheme.Background
        mainFrame.BackgroundTransparency = windowTransparency
        topbar.BackgroundColor3 = newTheme.Topbar
        topbar.BackgroundTransparency = topbarTransparency
        sidebar.BackgroundColor3 = newTheme.BackgroundSecondary
        sidebar.BackgroundTransparency = sidebarTransparency
        topbarAccent.BackgroundColor3 = newTheme.Accent
        hideBtn.BackgroundColor3 = newTheme.Error

        local backdrop = screenGui:FindFirstChild("BackdropDim")
        if backdrop and backdrop:IsA("Frame") then
            backdrop.BackgroundTransparency = newTheme.BackdropTransparency or 0.24
        end
        local glass = mainFrame:FindFirstChild("GlassOverlay")
        if glass and glass:IsA("ImageLabel") then
            glass.ImageColor3 = LerpColor(newTheme.TextPrimary, newTheme.Accent, 0.08)
            glass.ImageTransparency = newTheme.OverlayTransparency or 0.35
        end

        if newTheme.GlowEnabled then
            local glow = mainFrame:FindFirstChild("Glow")
            if glow and glow:IsA("ImageLabel") then
                glow.ImageColor3 = newTheme.Accent
            end
        end

        Exter:Notify({ Title = "Theme Changed", Content = "Switched to " .. themeName, Type = "Success", Duration = 2 })
    end

