function Exter:CreateWindow(settings)
    local theme = Exter.Theme
    if settings.Theme and Themes[settings.Theme] then
        Exter.Theme = Themes[settings.Theme]
        theme = Exter.Theme
    end

    if settings.ConfigurationSaving then
        ConfigEnabled = settings.ConfigurationSaving.Enabled or false
        ConfigFileName = settings.ConfigurationSaving.FileName or tostring(game.PlaceId)
        if ConfigEnabled then
            pcall(function()
                if not isfolder(LibraryFolder) then makefolder(LibraryFolder) end
                if not isfolder(ConfigFolder) then makefolder(ConfigFolder) end
            end)
        end
    end

    if settings.ToggleKey then Exter.ToggleKey = settings.ToggleKey end

    local screenGui = Create("ScreenGui", { Name = "ExterLib",
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling, ResetOnSpawn = false, DisplayOrder = 120 })
    pcall(function()
        if gethui then screenGui.Parent = gethui()
        elseif syn and syn.protect_gui then syn.protect_gui(screenGui); screenGui.Parent = CoreGui
        else screenGui.Parent = CoreGui end
    end)

    local parentContainer = screenGui.Parent
    for _, child in ipairs(parentContainer:GetChildren()) do
