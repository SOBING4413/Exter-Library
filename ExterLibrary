local NotificationContainer = nil

function Exter:Notify(settings)
    if not NotificationContainer then return end
    local theme = Exter.Theme
    local notifType = settings.Type or "Info"
    local duration = settings.Duration or DefaultNotificationDuration
    local accentColor = theme.Info
    if notifType == "Success" then accentColor = theme.Success
    elseif notifType == "Warning" then accentColor = theme.Warning
    elseif notifType == "Error" then accentColor = theme.Error end

    local notif = Create("Frame", {
        Name = "Notification", BackgroundColor3 = theme.NotificationBackground,
        BackgroundTransparency = 0.02, Size = UDim2.new(1, 0, 0, 0),
        ClipsDescendants = true, Parent = NotificationContainer,
    })
    AddCorner(notif, 12)
    AddStroke(notif, accentColor, 1, 0.6)
    if theme.GlowEnabled then AddGlow(notif, accentColor, 30, 0.88) end

    Create("Frame", { Name = "AccentLine", BackgroundColor3 = accentColor,
        Size = UDim2.new(0, 4, 1, -16), Position = UDim2.new(0, 8, 0, 8), Parent = notif })
    AddCorner(notif.AccentLine, 2)

    local iconText = "i"
    if notifType == "Success" then iconText = "v"
    elseif notifType == "Warning" then iconText = "!"
    elseif notifType == "Error" then iconText = "x" end

    local icon = Create("TextLabel", { Name = "Icon", BackgroundColor3 = accentColor,
        BackgroundTransparency = 0.82, Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(0, 20, 0, 14), Text = iconText,
        TextColor3 = accentColor, TextSize = 15, FontFace = theme.FontFaceBold, Parent = notif })
    AddCorner(icon, 8)

    Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
        Size = UDim2.new(1, -88, 0, 22), Position = UDim2.new(0, 58, 0, 12),
        Text = settings.Title or "Notification", TextColor3 = theme.TextPrimary,
        TextSize = 14, FontFace = theme.FontFaceBold, TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd, Parent = notif })

    Create("TextLabel", { Name = "Description", BackgroundTransparency = 1,
        Size = UDim2.new(1, -88, 0, 32), Position = UDim2.new(0, 58, 0, 32),
        Text = settings.Content or "", TextColor3 = theme.TextSecondary,
        TextSize = 12, FontFace = theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true, Parent = notif })

    local closeBtn = Create("TextButton", { Name = "Close", BackgroundColor3 = theme.ElementBackground,
        BackgroundTransparency = 0.5, Size = UDim2.new(0, 26, 0, 26),
        Position = UDim2.new(1, -34, 0, 12), Text = "X", TextColor3 = theme.TextMuted,
        TextSize = 14, FontFace = theme.FontFaceBold, AutoButtonColor = false, Parent = notif })
    AddCorner(closeBtn, 6)

    local progressBg = Create("Frame", { Name = "ProgressBg", BackgroundColor3 = theme.ElementBorder,
        BackgroundTransparency = 0.5, Size = UDim2.new(1, -20, 0, 3),
        Position = UDim2.new(0, 10, 1, -8), Parent = notif })
    AddCorner(progressBg, 2)
    local progressFill = Create("Frame", { Name = "ProgressFill", BackgroundColor3 = accentColor,
        Size = UDim2.new(1, 0, 1, 0), Parent = progressBg })
    AddCorner(progressFill, 2)

    local targetHeight = 76
    notif.BackgroundTransparency = 1
    Tween(notif, 0.45, { Size = UDim2.new(1, 0, 0, targetHeight), BackgroundTransparency = 0.02 })
    Tween(progressFill, duration, { Size = UDim2.new(0, 0, 1, 0) }, Enum.EasingStyle.Linear)

    local closed = false
    local function closeNotif()
        if closed then return end
        closed = true
        Tween(notif, 0.35, { Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1 })
        task.delay(0.4, function() notif:Destroy() end)
    end
    closeBtn.MouseButton1Click:Connect(closeNotif)
    task.delay(duration, closeNotif)
end

local function ApplyTheme(themeName)
    if not Themes[themeName] then return end
    Exter.Theme = Themes[themeName]
end

