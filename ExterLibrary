                Size = UDim2.new(1, 0, 0, 42), ClipsDescendants = true, Parent = tabPage })
            AddCorner(dropdown, 10)
            AddStroke(dropdown, Exter.Theme.ElementBorder, 1, 0.3)
            Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
                Size = UDim2.new(0.42, 0, 0, 42), Position = UDim2.new(0, 14, 0, 0),
                Text = dropdownSettings.Name or "Dropdown", TextColor3 = Exter.Theme.TextPrimary,
                TextSize = 14, FontFace = Exter.Theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = dropdown })
            local selectedLabel = Create("TextLabel", { Name = "Selected", BackgroundTransparency = 1,
                Size = UDim2.new(0.45, -35, 0, 42), Position = UDim2.new(0.5, 0, 0, 0),
                Text = #dropdownSettings.CurrentOption > 0 and dropdownSettings.CurrentOption[1] or "None",
                TextColor3 = Exter.Theme.TextSecondary, TextSize = 13, FontFace = Exter.Theme.FontFace,
                TextXAlignment = Enum.TextXAlignment.Right, TextTruncate = Enum.TextTruncate.AtEnd,
                Parent = dropdown })
            local arrow = Create("TextLabel", { Name = "Arrow", BackgroundTransparency = 1,
                Size = UDim2.new(0, 22, 0, 42), Position = UDim2.new(1, -28, 0, 0),
                Text = "V", TextColor3 = Exter.Theme.Accent, TextSize = 11, FontFace = Exter.Theme.FontFaceBold,
                Rotation = 0, Parent = dropdown })

            local optionsContainer = Create("Frame", { Name = "Options", BackgroundTransparency = 1,
                Size = UDim2.new(1, -14, 0, 0), Position = UDim2.new(0, 7, 0, 48),
                AutomaticSize = Enum.AutomaticSize.Y, Parent = dropdown })
            AddListLayout(optionsContainer, 3)

            local function updateSelectedText()
                if dropdownSettings.MultipleOptions then
                    if #dropdownSettings.CurrentOption == 0 then selectedLabel.Text = "None"
                    elseif #dropdownSettings.CurrentOption == 1 then selectedLabel.Text = dropdownSettings.CurrentOption[1]
                    else selectedLabel.Text = #dropdownSettings.CurrentOption .. " selected" end
                else selectedLabel.Text = (dropdownSettings.CurrentOption[1] or "None") end
            end
            updateSelectedText()

            local function createOption(optionName)
                local isSel = table.find(dropdownSettings.CurrentOption, optionName) ~= nil
                local optionBtn = Create("TextButton", { Name = optionName,
                    BackgroundColor3 = isSel and LerpColor(Exter.Theme.DropdownBackground, Exter.Theme.Accent, 0.15) or Exter.Theme.DropdownBackground,
                    Size = UDim2.new(1, 0, 0, 34), Text = "", AutoButtonColor = false, Parent = optionsContainer })
                AddCorner(optionBtn, 8)
                local optTitle = Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
                    Size = UDim2.new(1, -34, 1, 0), Position = UDim2.new(0, 12, 0, 0),
                    Text = optionName, TextColor3 = isSel and Exter.Theme.Accent or Exter.Theme.TextSecondary,
                    TextSize = 13, FontFace = Exter.Theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = optionBtn })
                local checkmark = Create("TextLabel", { Name = "Check", BackgroundTransparency = 1,
                    Size = UDim2.new(0, 22, 1, 0), Position = UDim2.new(1, -26, 0, 0),
                    Text = isSel and "v" or "", TextColor3 = Exter.Theme.Accent, TextSize = 14,
                    FontFace = Exter.Theme.FontFaceBold, Parent = optionBtn })

                optionBtn.MouseEnter:Connect(function() Tween(optionBtn, 0.15, { BackgroundColor3 = Exter.Theme.DropdownItemHover }) end)
                optionBtn.MouseLeave:Connect(function()
                    local sel = table.find(dropdownSettings.CurrentOption, optionName) ~= nil
                    Tween(optionBtn, 0.15, { BackgroundColor3 = sel and LerpColor(Exter.Theme.DropdownBackground, Exter.Theme.Accent, 0.15) or Exter.Theme.DropdownBackground })
                end)
                optionBtn.MouseButton1Click:Connect(function()
                    if dropdownSettings.MultipleOptions then
                        local idx = table.find(dropdownSettings.CurrentOption, optionName)
                        if idx then
                            table.remove(dropdownSettings.CurrentOption, idx)
                            checkmark.Text = ""
                            Tween(optTitle, 0.2, { TextColor3 = Exter.Theme.TextSecondary })
                        else
                            table.insert(dropdownSettings.CurrentOption, optionName)
                            checkmark.Text = "v"
                            Tween(optTitle, 0.2, { TextColor3 = Exter.Theme.Accent })
                        end
                    else
                        dropdownSettings.CurrentOption = {optionName}
                        for _, child in ipairs(optionsContainer:GetChildren()) do
                            if child:IsA("TextButton") then
                                local cT = child:FindFirstChild("Title")
                                local cC = child:FindFirstChild("Check")
                                if child.Name == optionName then
                                    if cC then cC.Text = "v" end
                                    if cT then Tween(cT, 0.2, { TextColor3 = Exter.Theme.Accent }) end
                                else
                                    if cC then cC.Text = "" end
                                    if cT then Tween(cT, 0.2, { TextColor3 = Exter.Theme.TextSecondary }) end
                                end
                            end
                        end
                        task.delay(0.15, function()
                            isOpen = false
                            Tween(dropdown, 0.3, { Size = UDim2.new(1, 0, 0, 42) })
                            Tween(arrow, 0.3, { Rotation = 0 })
                        end)
                    end
                    updateSelectedText()
                    pcall(dropdownSettings.Callback, dropdownSettings.CurrentOption)
                    SaveConfiguration()
                end)
                return optionBtn
            end

            for _, option in ipairs(dropdownSettings.Options or {}) do createOption(option) end

            local interact = Create("TextButton", { Name = "Interact", BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 42), Text = "", ZIndex = 5, Parent = dropdown })
            interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                if isOpen then
                    local optionCount = #(dropdownSettings.Options or {})
                    local targetHeight = 42 + 8 + math.min(optionCount, 5) * 37
                    Tween(dropdown, 0.35, { Size = UDim2.new(1, 0, 0, targetHeight) })
                    Tween(arrow, 0.35, { Rotation = 180 })
                else
                    Tween(dropdown, 0.35, { Size = UDim2.new(1, 0, 0, 42) })
                    Tween(arrow, 0.35, { Rotation = 0 })
                end
            end)

            function dropdownSettings:Refresh(newOptionsList)
                dropdownSettings.Options = newOptionsList
                for _, child in ipairs(optionsContainer:GetChildren()) do
                    if child:IsA("TextButton") then child:Destroy() end
                end
                for _, option in ipairs(newOptionsList) do createOption(option) end
                local validOptions = {}
                for _, opt in ipairs(dropdownSettings.CurrentOption) do
                    if table.find(newOptionsList, opt) then
                        table.insert(validOptions, opt)
                    end
                end
                dropdownSettings.CurrentOption = validOptions
                updateSelectedText()
            end

            function dropdownSettings:Set(newOptions)
                if typeof(newOptions) == "string" then newOptions = {newOptions} end
                dropdownSettings.CurrentOption = newOptions
                updateSelectedText()
                for _, child in ipairs(optionsContainer:GetChildren()) do
                    if child:IsA("TextButton") then
                        local sel = table.find(newOptions, child.Name) ~= nil
                        local cT = child:FindFirstChild("Title")
                        local cC = child:FindFirstChild("Check")
                        if cC then cC.Text = sel and "v" or "" end
                        if cT then cT.TextColor3 = sel and Exter.Theme.Accent or Exter.Theme.TextSecondary end
                    end
                end
                pcall(dropdownSettings.Callback, newOptions); SaveConfiguration()
            end
            if dropdownSettings.Flag then Exter.Flags[dropdownSettings.Flag] = dropdownSettings end
            return dropdownSettings
        end

        function Tab:CreateKeybind(keybindSettings)
            keybindSettings.Type = "Keybind"
            keybindSettings.CurrentKeybind = keybindSettings.CurrentKeybind or "E"
            local keybind = Create("Frame", { Name = "Keybind_" .. (keybindSettings.Name or "Keybind"),
                BackgroundColor3 = Exter.Theme.ElementBackground, BackgroundTransparency = 0.15,
                Size = UDim2.new(1, 0, 0, 42), Parent = tabPage })
            AddCorner(keybind, 10)
            AddStroke(keybind, Exter.Theme.ElementBorder, 1, 0.3)
            Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
                Size = UDim2.new(0.6, 0, 1, 0), Position = UDim2.new(0, 14, 0, 0),
                Text = keybindSettings.Name or "Keybind", TextColor3 = Exter.Theme.TextPrimary,
                TextSize = 14, FontFace = Exter.Theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = keybind })
            local keybindBox = Create("TextButton", { Name = "KeyBox", BackgroundColor3 = Exter.Theme.InputBackground,
                Size = UDim2.new(0, 70, 0, 30), Position = UDim2.new(1, -82, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5), Text = keybindSettings.CurrentKeybind,
                TextColor3 = Exter.Theme.Accent, TextSize = 13, FontFace = Exter.Theme.FontFaceBold,
                AutoButtonColor = false, Parent = keybind })
            AddCorner(keybindBox, 8)
            AddStroke(keybindBox, Exter.Theme.InputBorder, 1, 0.3)

            local listening = false
            keybindBox.MouseButton1Click:Connect(function()
                listening = true
                keybindBox.Text = "..."
                local stroke = keybindBox:FindFirstChildOfClass("UIStroke")
                if stroke then Tween(stroke, 0.2, { Color = Exter.Theme.Accent }) end
            end)
            TrackConnection(UserInputService.InputBegan:Connect(function(input, processed)
                if listening then
                    if input.KeyCode ~= Enum.KeyCode.Unknown then
                        keybindSettings.CurrentKeybind = input.KeyCode.Name
                        keybindBox.Text = input.KeyCode.Name
                        listening = false
                        local stroke = keybindBox:FindFirstChildOfClass("UIStroke")
                        if stroke then Tween(stroke, 0.2, { Color = Exter.Theme.InputBorder }) end
                        SaveConfiguration()
                    end
                elseif not processed and keybindSettings.CurrentKeybind then
                    pcall(function()
                        if input.KeyCode == Enum.KeyCode[keybindSettings.CurrentKeybind] then
                            pcall(keybindSettings.Callback)
                        end
                    end)
                end
            end))
            keybind.MouseEnter:Connect(function()
                Tween(keybind, 0.25, { BackgroundColor3 = Exter.Theme.ElementBackgroundHover, BackgroundTransparency = 0.05 })
            end)
            keybind.MouseLeave:Connect(function()
                Tween(keybind, 0.25, { BackgroundColor3 = Exter.Theme.ElementBackground, BackgroundTransparency = 0.15 })
            end)
            function keybindSettings:Set(newKey)
                keybindSettings.CurrentKeybind = newKey; keybindBox.Text = newKey; SaveConfiguration()
            end
            if keybindSettings.Flag then Exter.Flags[keybindSettings.Flag] = keybindSettings end
            return keybindSettings
        end

        function Tab:CreateColorPicker(cpSettings)
            cpSettings.Type = "ColorPicker"
            cpSettings.Color = cpSettings.Color or Color3.fromRGB(255, 255, 255)
            local isOpen = false
            local h, s, v = cpSettings.Color:ToHSV()

            local cpFrame = Create("Frame", { Name = "ColorPicker_" .. (cpSettings.Name or "ColorPicker"),
                BackgroundColor3 = Exter.Theme.ElementBackground, BackgroundTransparency = 0.15,
                Size = UDim2.new(1, 0, 0, 42), ClipsDescendants = true, Parent = tabPage })
            AddCorner(cpFrame, 10)
            AddStroke(cpFrame, Exter.Theme.ElementBorder, 1, 0.3)
            Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
                Size = UDim2.new(0.6, 0, 0, 42), Position = UDim2.new(0, 14, 0, 0),
                Text = cpSettings.Name or "Color Picker", TextColor3 = Exter.Theme.TextPrimary,
                TextSize = 14, FontFace = Exter.Theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = cpFrame })
            local colorPreview = Create("Frame", { Name = "Preview", BackgroundColor3 = cpSettings.Color,
                Size = UDim2.new(0, 32, 0, 26), Position = UDim2.new(1, -46, 0, 8), Parent = cpFrame })
            AddCorner(colorPreview, 8)
            AddStroke(colorPreview, Exter.Theme.ElementBorder, 1, 0.3)

            local pickerArea = Create("Frame", { Name = "PickerArea", BackgroundTransparency = 1,
                Size = UDim2.new(1, -16, 0, 130), Position = UDim2.new(0, 8, 0, 48), Parent = cpFrame })
            local svPicker = Create("ImageLabel", { Name = "SVPicker",
                BackgroundColor3 = Color3.fromHSV(h, 1, 1), Size = UDim2.new(1, -32, 0, 100),
                Image = "rbxassetid://11415645739", Parent = pickerArea })
            AddCorner(svPicker, 6)
            local svPoint = Create("Frame", { Name = "Point", BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(s, -7, 1 - v, -7),
                ZIndex = 5, Parent = svPicker })
            AddCorner(svPoint, 7)
            AddStroke(svPoint, Color3.fromRGB(0, 0, 0), 2, 0.3)

            local hueSlider = Create("Frame", { Name = "HueSlider", Size = UDim2.new(0, 20, 0, 100),
                Position = UDim2.new(1, -22, 0, 0), Parent = pickerArea })
            AddCorner(hueSlider, 4)
            AddGradient(hueSlider, ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
                ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167, 1, 1)),
                ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333, 1, 1)),
                ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
                ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667, 1, 1)),
                ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833, 1, 1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
            }), 90)
            local huePoint = Create("Frame", { Name = "HuePoint", BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(1, 4, 0, 8), Position = UDim2.new(-0.1, 0, h, -4),
                ZIndex = 5, Parent = hueSlider })
            AddCorner(huePoint, 3)
            AddStroke(huePoint, Color3.fromRGB(0, 0, 0), 1, 0.3)

            local hexInput = Create("TextBox", { Name = "HexInput", BackgroundColor3 = Exter.Theme.InputBackground,
                Size = UDim2.new(0.5, -4, 0, 24), Position = UDim2.new(0, 0, 0, 106),
                Text = string.format("#%02X%02X%02X", math.floor(cpSettings.Color.R * 255), math.floor(cpSettings.Color.G * 255), math.floor(cpSettings.Color.B * 255)),
                TextColor3 = Exter.Theme.TextPrimary, TextSize = 12, FontFace = Exter.Theme.FontFace,
                ClearTextOnFocus = false, Parent = pickerArea })
            AddCorner(hexInput, 4)
            AddStroke(hexInput, Exter.Theme.InputBorder, 1, 0.5)

            local interact = Create("TextButton", { Name = "Interact", BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 42), Text = "", ZIndex = 5, Parent = cpFrame })
            interact.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(cpFrame, 0.35, { Size = UDim2.new(1, 0, 0, isOpen and 195 or 42) })
            end)

            local function updateColor()
                local color = Color3.fromHSV(h, s, v)
                cpSettings.Color = color
                colorPreview.BackgroundColor3 = color
                svPicker.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svPoint.Position = UDim2.new(s, -7, 1 - v, -7)
                svPoint.BackgroundColor3 = color
                huePoint.Position = UDim2.new(-0.1, 0, h, -4)
                hexInput.Text = string.format("#%02X%02X%02X", math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255))
                pcall(cpSettings.Callback, color); SaveConfiguration()
            end

            local svDragging, hueDragging = false, false
            svPicker.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    svDragging = true
                end
            end)
            hueSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    hueDragging = true
                end
            end)
            TrackConnection(UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    svDragging = false
                    hueDragging = false
                end
            end))
            TrackConnection(RunService.RenderStepped:Connect(function()
                if svDragging then
                    local svSizeX = svPicker.AbsoluteSize.X
                    local svSizeY = svPicker.AbsoluteSize.Y
                    if svSizeX > 0 and svSizeY > 0 then
                        s = math.clamp((Mouse.X - svPicker.AbsolutePosition.X) / svSizeX, 0, 1)
                        v = 1 - math.clamp((Mouse.Y - svPicker.AbsolutePosition.Y) / svSizeY, 0, 1)
                        updateColor()
                    end
                end
                if hueDragging then
                    local hueSizeY = hueSlider.AbsoluteSize.Y
                    if hueSizeY > 0 then
                        h = math.clamp((Mouse.Y - hueSlider.AbsolutePosition.Y) / hueSizeY, 0, 1)
                        updateColor()
                    end
                end
            end))
            hexInput.FocusLost:Connect(function()
                pcall(function()
                    local hex = hexInput.Text:gsub("#", "")
                    if #hex == 6 then
                        local r = tonumber(hex:sub(1, 2), 16)
                        local g = tonumber(hex:sub(3, 4), 16)
                        local b = tonumber(hex:sub(5, 6), 16)
                        if r and g and b then h, s, v = Color3.fromRGB(r, g, b):ToHSV(); updateColor() end
                    end
                end)
            end)
            function cpSettings:Set(newColor) h, s, v = newColor:ToHSV(); cpSettings.Color = newColor; updateColor() end
            if cpSettings.Flag then Exter.Flags[cpSettings.Flag] = cpSettings end
            return cpSettings
        end

        return Tab
    end

    function Window:SetWindowOpacity(value)
        local amount = math.clamp(tonumber(value) or 0.08, 0, 0.55)
        mainFrame.BackgroundTransparency = amount
        local glass = mainFrame:FindFirstChild("GlassOverlay")
        if glass and glass:IsA("ImageLabel") then
            glass.ImageTransparency = math.clamp(amount + 0.24, 0.2, 0.82)
        end
    end

    function Window:SetBackdropOpacity(value)
        local amount = math.clamp(tonumber(value) or 0.24, 0, 0.85)
        local backdrop = screenGui:FindFirstChild("BackdropDim")
        if backdrop and backdrop:IsA("Frame") then
            backdrop.BackgroundTransparency = amount
        end
    end

    function Window:SetCompactMode(enabled)
        if enabled then
            layout.Compact = true
            layout.SidebarWidth = 126
            layout.TopbarHeight = 46
        else
            local _, latestViewport = EvaluateResponsiveScale()
            local rebuilt = BuildWindowLayoutPresets(latestViewport)
            layout.Compact = rebuilt.Compact
            layout.SidebarWidth = rebuilt.SidebarWidth
            layout.TopbarHeight = rebuilt.TopbarHeight
        end
        ReflowResponsiveLayout()
    end

    function Window:PulseAccent(times)
        times = math.clamp(math.floor(tonumber(times) or 1), 1, 8)
        task.spawn(function()
            for _ = 1, times do
                Tween(topbarAccent, 0.22, { BackgroundTransparency = 0.18 })
                task.wait(0.22)
                Tween(topbarAccent, 0.28, { BackgroundTransparency = 0 })
                task.wait(0.28)
            end
        end)
    end

    function Window:SetMotionProfile(profileName)
        if SetMotionProfile(profileName) then
            Exter:Notify({
                Title = "Motion Profile",
                Content = "Profile switched to " .. tostring(profileName),
                Type = "Info",
                Duration = 2,
            })
            return true
        end
        Exter:Notify({
            Title = "Motion Profile",
            Content = "Unknown profile: " .. tostring(profileName),
            Type = "Warning",
            Duration = 2,
        })
        return false
    end

    function Window:GetAvailableThemes()
        local names = {}
        for name in pairs(Themes) do
            table.insert(names, name)
        end
        table.sort(names)
        return names
    end

    function Window:GetAvailableMotionProfiles()
        local names = {}
        for name in pairs(MotionProfiles) do
            table.insert(names, name)
        end
        table.sort(names)
        return names
    end

    function Window:LoadConfiguration()
        if ConfigEnabled and ConfigFileName then
            pcall(function()
                local path = ConfigFolder .. "/" .. ConfigFileName .. ConfigExtension
                if isfile(path) then
                    LoadConfiguration(readfile(path))
                    Exter:Notify({ Title = "Config Loaded", Content = "Settings restored.", Type = "Success", Duration = 3 })
                end
            end)
        end
    end

    task.delay(2.5, function() Window:LoadConfiguration() end)
    return Window
end

function Exter:SetMotionProfile(profileName)
    return SetMotionProfile(profileName)
end

function Exter:GetMotionProfile()
    return GetMotionProfile()
end

function Exter:Destroy()
    for _, conn in ipairs(Exter._connections) do
        pcall(function() conn:Disconnect() end)
    end
    Exter._connections = {}
    Exter.Flags = {}
    NotificationContainer = nil
    if Exter.ScreenGui then Exter.ScreenGui:Destroy(); Exter.ScreenGui = nil end
end

return Exter
