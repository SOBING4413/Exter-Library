-- PREMIUM FULLSCREEN LOADING SCREEN
-- ═══════════════════════════════════════════════════════════

local function CreateFullscreenLoadingScreen(screenGui, settings, theme)
    local loadScreen = Create("Frame", { Name = "FullscreenLoading",
        BackgroundColor3 = Color3.fromRGB(0, 0, 0), Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 100, Parent = screenGui })

    local bgGradient = Create("Frame", { Name = "BGGradient", BackgroundColor3 = theme.Background,
        Size = UDim2.new(1, 0, 1, 0), ZIndex = 100, Parent = loadScreen })
    local gradientEffect = AddGradient(bgGradient, ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
        ColorSequenceKeypoint.new(0.5, LerpColor(theme.Background, theme.Accent, 0.08)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0)),
    }), 45)

    -- Animated gradient rotation
    task.spawn(function()
        local rot = 45
        while loadScreen.Parent do
            rot = rot + 0.3
            gradientEffect.Rotation = rot
            task.wait()
        end
    end)

    -- Floating particles
    for i = 1, 12 do
        local particle = Create("Frame", { Name = "Particle" .. i,
            BackgroundColor3 = theme.Accent, BackgroundTransparency = math.random(75, 95) / 100,
            Size = UDim2.new(0, math.random(2, 6), 0, math.random(2, 6)),
            Position = UDim2.new(math.random() * 0.8 + 0.1, 0, math.random() * 0.8 + 0.1, 0),
            ZIndex = 101, Parent = loadScreen })
        AddCorner(particle, 999)
        task.spawn(function()
            while particle.Parent do
                Tween(particle, math.random(30, 80) / 10, {
                    Position = UDim2.new(math.random() * 0.8 + 0.1, 0, math.random() * 0.8 + 0.1, 0),
                    BackgroundTransparency = math.random(70, 95) / 100,
                }, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                task.wait(math.random(30, 80) / 10)
            end
        end)
    end

    -- Center container
    local center = Create("Frame", { Name = "Center", BackgroundTransparency = 1,
        Size = UDim2.new(0, 400, 0, 300), Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5), ZIndex = 102, Parent = loadScreen })

    -- Logo circle with animated ring
    local logoCont = Create("Frame", { Name = "LogoContainer", BackgroundTransparency = 1,
        Size = UDim2.new(0, 80, 0, 80), Position = UDim2.new(0.5, 0, 0, 20),
        AnchorPoint = Vector2.new(0.5, 0), ZIndex = 103, Parent = center })

    local outerRing = Create("Frame", { Name = "OuterRing", BackgroundTransparency = 1,
        Size = UDim2.new(1, 16, 1, 16), Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5), ZIndex = 103, Parent = logoCont })
    AddCorner(outerRing, 999)
    local outerStroke = AddStroke(outerRing, theme.Accent, 2, 0)
    local ringGrad = AddGradient(outerStroke, ColorSequence.new({
        ColorSequenceKeypoint.new(0, theme.GradientAccent1),
        ColorSequenceKeypoint.new(0.5, theme.GradientAccent2),
        ColorSequenceKeypoint.new(1, theme.GradientAccent1),
    }), 0)

    task.spawn(function()
        local ringRot = 0
        while outerRing.Parent do
            ringRot = ringRot + 2
            ringGrad.Rotation = ringRot
            task.wait()
        end
    end)

    local logoCircle = Create("Frame", { Name = "LogoCircle",
        BackgroundColor3 = LerpColor(theme.Background, theme.Accent, 0.12),
        Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5), ZIndex = 104, Parent = logoCont })
    AddCorner(logoCircle, 999)
    AddStroke(logoCircle, theme.Accent, 1, 0.5)

    Create("TextLabel", { Name = "LogoText", BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0), Text = "E", TextColor3 = theme.Accent,
        TextSize = 36, FontFace = theme.FontFaceBold, ZIndex = 105, Parent = logoCircle })

    -- Pulse animation
    task.spawn(function()
        while logoCircle.Parent do
            Tween(logoCircle, 1.2, { Size = UDim2.new(1, 4, 1, 4) }, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1.2)
            Tween(logoCircle, 1.2, { Size = UDim2.new(1, 0, 1, 0) }, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            task.wait(1.2)
        end
    end)

    local loadTitle = Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 36), Position = UDim2.new(0, 0, 0, 115),
        Text = settings.LoadingTitle or "EXTER LIBRARY", TextColor3 = theme.TextPrimary,
        TextTransparency = 1, TextSize = 28, FontFace = theme.FontFaceBold,
        ZIndex = 103, Parent = center })

    local loadSub = Create("TextLabel", { Name = "Subtitle", BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 22), Position = UDim2.new(0, 0, 0, 152),
        Text = settings.LoadingSubtitle or "Premium Edition", TextColor3 = theme.TextSecondary,
        TextTransparency = 1, TextSize = 14, FontFace = theme.FontFace,
        ZIndex = 103, Parent = center })

    local statusText = Create("TextLabel", { Name = "Status", BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 18), Position = UDim2.new(0, 0, 0, 220),
        Text = "Initializing...", TextColor3 = theme.TextMuted, TextTransparency = 1,
        TextSize = 12, FontFace = theme.FontFace, ZIndex = 103, Parent = center })

    local barCont = Create("Frame", { Name = "BarContainer", BackgroundTransparency = 1,
        Size = UDim2.new(0.65, 0, 0, 24), Position = UDim2.new(0.175, 0, 0, 188),
        ZIndex = 103, Parent = center })

    local loadBarBg = Create("Frame", { Name = "LoadBarBg",
        BackgroundColor3 = LerpColor(theme.Background, theme.ElementBackground, 0.5),
        BackgroundTransparency = 0.3, Size = UDim2.new(1, 0, 0, 6),
        Position = UDim2.new(0, 0, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5),
        ZIndex = 103, Parent = barCont })
    AddCorner(loadBarBg, 3)
    AddStroke(loadBarBg, theme.ElementBorder, 1, 0.6)

    local loadBarFill = Create("Frame", { Name = "Fill", BackgroundColor3 = theme.Accent,
        Size = UDim2.new(0, 0, 1, 0), ZIndex = 104, Parent = loadBarBg })
    AddCorner(loadBarFill, 3)
    AddGradient(loadBarFill, ColorSequence.new({
        ColorSequenceKeypoint.new(0, theme.GradientAccent1),
        ColorSequenceKeypoint.new(1, theme.GradientAccent2),
    }))

    local percentText = Create("TextLabel", { Name = "Percent", BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 1, 4),
        Text = "0%", TextColor3 = theme.Accent, TextTransparency = 1,
        TextSize = 11, FontFace = theme.FontFaceBold, ZIndex = 103, Parent = barCont })

    local versionText = Create("TextLabel", { Name = "Version", BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 0, 260),
        Text = Release, TextColor3 = theme.TextMuted, TextTransparency = 1,
        TextSize = 10, FontFace = theme.FontFace, ZIndex = 103, Parent = center })

    local creditsText = Create("TextLabel", { Name = "Credits", BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 16), Position = UDim2.new(0, 0, 1, -30),
        Text = "Made with love by Exter Team", TextColor3 = theme.TextMuted,
        TextTransparency = 1, TextSize = 10, FontFace = theme.FontFace,
        ZIndex = 103, Parent = loadScreen })

    -- Loading animation sequence
    task.spawn(function()
        task.wait(0.2)
        Tween(loadTitle, 0.6, { TextTransparency = 0 })
        task.wait(0.15)
        Tween(loadSub, 0.5, { TextTransparency = 0 })
        task.wait(0.15)
        Tween(statusText, 0.4, { TextTransparency = 0 })
        Tween(percentText, 0.4, { TextTransparency = 0 })
        Tween(versionText, 0.4, { TextTransparency = 0 })
        Tween(creditsText, 0.4, { TextTransparency = 0 })

        local statuses = {
            {0.15, "Checking environment..."},
            {0.30, "Loading modules..."},
            {0.50, "Initializing UI framework..."},
            {0.65, "Applying theme..."},
            {0.80, "Building interface..."},
            {0.92, "Almost ready..."},
            {1.00, "Welcome!"},
        }
        for _, status in ipairs(statuses) do
            statusText.Text = status[2]
            Tween(loadBarFill, 0.35, { Size = UDim2.new(status[1], 0, 1, 0) }, Enum.EasingStyle.Quart)
            percentText.Text = math.floor(status[1] * 100) .. "%"
            task.wait(math.random(18, 35) / 100)
        end

        task.wait(0.2)
        statusText.Text = "Ready!"
        statusText.TextColor3 = theme.Success
        task.wait(0.4)

        Tween(loadTitle, 0.4, { TextTransparency = 1 })
        Tween(loadSub, 0.35, { TextTransparency = 1 })
        Tween(statusText, 0.3, { TextTransparency = 1 })
        Tween(percentText, 0.3, { TextTransparency = 1 })
        Tween(versionText, 0.3, { TextTransparency = 1 })
        Tween(creditsText, 0.3, { TextTransparency = 1 })
        task.wait(0.3)
        Tween(loadScreen, 0.5, { BackgroundTransparency = 1 })
        Tween(bgGradient, 0.5, { BackgroundTransparency = 1 })
        for _, child in ipairs(loadScreen:GetChildren()) do
            if child.Name:find("Particle") then
                Tween(child, 0.3, { BackgroundTransparency = 1 })
            end
        end
        task.wait(0.55)
        loadScreen:Destroy()
    end)

    return loadScreen
end

