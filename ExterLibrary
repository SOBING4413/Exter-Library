        function Tab:CreateSlider(sliderSettings)
            sliderSettings.Type = "Slider"
            local range = sliderSettings.Range or {0, 100}
            local increment = sliderSettings.Increment or 1
            sliderSettings.CurrentValue = sliderSettings.CurrentValue or range[1]

            local rangeSpan = range[2] - range[1]
            if rangeSpan == 0 then rangeSpan = 1 end

            local slider = Create("Frame", { Name = "Slider_" .. (sliderSettings.Name or "Slider"),
                BackgroundColor3 = Exter.Theme.ElementBackground, BackgroundTransparency = 0.15,
                Size = UDim2.new(1, 0, 0, 56), Parent = tabPage })
            AddCorner(slider, 10)
            AddStroke(slider, Exter.Theme.ElementBorder, 1, 0.3)
            Create("TextLabel", { Name = "Title", BackgroundTransparency = 1,
                Size = UDim2.new(0.6, 0, 0, 24), Position = UDim2.new(0, 14, 0, 6),
                Text = sliderSettings.Name or "Slider", TextColor3 = Exter.Theme.TextPrimary,
                TextSize = 14, FontFace = Exter.Theme.FontFace, TextXAlignment = Enum.TextXAlignment.Left,
                Parent = slider })
            local valueLabel = Create("TextLabel", { Name = "Value", BackgroundColor3 = Exter.Theme.Accent,
                BackgroundTransparency = 0.82, Size = UDim2.new(0, 60, 0, 22),
                Position = UDim2.new(1, -72, 0, 8),
                Text = tostring(sliderSettings.CurrentValue) .. (sliderSettings.Suffix and " " .. sliderSettings.Suffix or ""),
                TextColor3 = Exter.Theme.Accent, TextSize = 12, FontFace = Exter.Theme.FontFaceBold, Parent = slider })
            AddCorner(valueLabel, 6)

            local sliderTrack = Create("Frame", { Name = "Track", BackgroundColor3 = Exter.Theme.SliderBackground,
                Size = UDim2.new(1, -28, 0, 8), Position = UDim2.new(0, 14, 0, 38), Parent = slider })
            AddCorner(sliderTrack, 4)
            local initialPercent = math.clamp((sliderSettings.CurrentValue - range[1]) / rangeSpan, 0, 1)
            local sliderFill = Create("Frame", { Name = "Fill", BackgroundColor3 = Exter.Theme.SliderFill,
                Size = UDim2.new(initialPercent, 0, 1, 0), Parent = sliderTrack })
            AddCorner(sliderFill, 4)
            AddGradient(sliderFill, ColorSequence.new({
                ColorSequenceKeypoint.new(0, Exter.Theme.GradientAccent1),
                ColorSequenceKeypoint.new(1, Exter.Theme.GradientAccent2),
            }))
            local sliderKnob = Create("Frame", { Name = "Knob", BackgroundColor3 = Exter.Theme.SliderKnob,
                Size = UDim2.new(0, 18, 0, 18),
                Position = UDim2.new(initialPercent, -9, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5), ZIndex = 3, Parent = sliderTrack })
            AddCorner(sliderKnob, 9)
            AddShadow(sliderKnob, 0.5, 8)
            AddStroke(sliderKnob, Exter.Theme.Accent, 2, 0.3)

            local sliderDragging = false
            local interact = Create("TextButton", { Name = "Interact", BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 14), Position = UDim2.new(0, 0, 0, -7),
                Text = "", ZIndex = 5, Parent = sliderTrack })

            local function updateSlider(inputX)
                local trackPos = sliderTrack.AbsolutePosition.X
                local trackSize = sliderTrack.AbsoluteSize.X
                if trackSize == 0 then return end
                local relativeX = math.clamp((inputX - trackPos) / trackSize, 0, 1)
                local rawValue = range[1] + relativeX * rangeSpan
                local newValue = math.floor(rawValue / increment + 0.5) * increment
                newValue = math.clamp(newValue, range[1], range[2])
                newValue = tonumber(string.format("%.6f", newValue))
                local percent = math.clamp((newValue - range[1]) / rangeSpan, 0, 1)
                Tween(sliderFill, 0.08, { Size = UDim2.new(percent, 0, 1, 0) })
                Tween(sliderKnob, 0.08, { Position = UDim2.new(percent, -9, 0.5, 0) })
                valueLabel.Text = tostring(newValue) .. (sliderSettings.Suffix and " " .. sliderSettings.Suffix or "")
                if sliderSettings.CurrentValue ~= newValue then
                    sliderSettings.CurrentValue = newValue
                    pcall(sliderSettings.Callback, newValue)
                    SaveConfiguration()
                end
            end

            interact.MouseButton1Down:Connect(function()
                sliderDragging = true
                updateSlider(Mouse.X)
            end)
            TrackConnection(UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    sliderDragging = false
                end
            end))

            TrackConnection(RunService.RenderStepped:Connect(function()
                if sliderDragging then updateSlider(Mouse.X) end
            end))
            slider.MouseEnter:Connect(function()
                Tween(slider, 0.25, { BackgroundColor3 = Exter.Theme.ElementBackgroundHover, BackgroundTransparency = 0.05 })
            end)
            slider.MouseLeave:Connect(function()
                Tween(slider, 0.25, { BackgroundColor3 = Exter.Theme.ElementBackground, BackgroundTransparency = 0.15 })
            end)

            function sliderSettings:Set(newValue)
                newValue = math.clamp(newValue, range[1], range[2])
                sliderSettings.CurrentValue = newValue
                local percent = math.clamp((newValue - range[1]) / rangeSpan, 0, 1)
                Tween(sliderFill, 0.3, { Size = UDim2.new(percent, 0, 1, 0) })
                Tween(sliderKnob, 0.3, { Position = UDim2.new(percent, -9, 0.5, 0) })
                valueLabel.Text = tostring(newValue) .. (sliderSettings.Suffix and " " .. sliderSettings.Suffix or "")
                pcall(sliderSettings.Callback, newValue); SaveConfiguration()
            end
            if sliderSettings.Flag then Exter.Flags[sliderSettings.Flag] = sliderSettings end
            return sliderSettings
        end

