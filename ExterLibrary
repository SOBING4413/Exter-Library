        ZIndex = 0,
        Visible = false,
        Parent = parent,
    })
    AddGradient(dim, ColorSequence.new({
        ColorSequenceKeypoint.new(0, LerpColor(theme.Background, Color3.new(0, 0, 0), 0.4)),
        ColorSequenceKeypoint.new(1, LerpColor(theme.BackgroundSecondary, Color3.new(0, 0, 0), 0.5)),
    }), 122)

    local noise = Create("ImageLabel", {
        Name = "Noise",
        BackgroundTransparency = 1,
        Image = "rbxassetid://9968344227",
        ImageColor3 = theme.TextMuted,
        ImageTransparency = 1,
        ScaleType = Enum.ScaleType.Tile,
        TileSize = UDim2.fromOffset(180, 180),
        Size = UDim2.fromScale(1, 1),
        ZIndex = 0,
        Parent = dim,
    })

    local vignette = Create("ImageLabel", {
        Name = "Vignette",
        BackgroundTransparency = 1,
        Image = "rbxassetid://4576475446",
        ImageColor3 = Color3.fromRGB(0, 0, 0),
        ImageTransparency = 1,
        Size = UDim2.fromScale(1, 1),
        ZIndex = 0,
        Parent = dim,
    })

    return dim, noise, vignette
end

local function CreateAmbientOrbs(parent, theme)
    local orbLayer = Create("Frame", {
        Name = "AmbientOrbs",
        BackgroundTransparency = 1,
        Size = UDim2.fromScale(1, 1),
        ZIndex = 1,
        Visible = false,
        Parent = parent,
    })

    local orbPalette = {
        LerpColor(theme.Accent, theme.GradientAccent1, 0.2),
        LerpColor(theme.Accent, theme.GradientAccent2, 0.25),
        LerpColor(theme.GradientAccent1, theme.GradientAccent2, 0.35),
    }

    local seeds = {
        {0.08, 0.17, 220},
        {0.82, 0.21, 180},
        {0.18, 0.78, 260},
        {0.85, 0.84, 200},
    }

    for idx, seed in ipairs(seeds) do
        local orb = Create("Frame", {
            Name = "Orb" .. idx,
            BackgroundColor3 = orbPalette[((idx - 1) % #orbPalette) + 1],
            BackgroundTransparency = 0.86,
            Size = UDim2.fromOffset(seed[3], seed[3]),
            Position = UDim2.fromScale(seed[1], seed[2]),
            AnchorPoint = Vector2.new(0.5, 0.5),
            ZIndex = 1,
            Parent = orbLayer,
        })
        AddCorner(orb, 999)
        AddGradient(orb, ColorSequence.new({
            ColorSequenceKeypoint.new(0, LerpColor(theme.Accent, Color3.new(1, 1, 1), 0.12)),
            ColorSequenceKeypoint.new(1, LerpColor(theme.AccentDark, Color3.new(0, 0, 0), 0.15)),
        }), idx * 35)

        task.spawn(function()
            while orb.Parent and orbLayer.Parent do
                local randScale = math.random(88, 122) / 100
                local jitterX = math.random(-80, 80)
                local jitterY = math.random(-60, 60)
                Tween(orb, 5 + idx, {
                    Position = UDim2.new(seed[1], jitterX, seed[2], jitterY),
                    Size = UDim2.fromOffset(math.floor(seed[3] * randScale), math.floor(seed[3] * randScale)),
                    BackgroundTransparency = 0.84 + (math.random(0, 8) / 100),
                }, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                task.wait(5 + idx)
            end
        end)
    end

    return orbLayer
end

local function ApplyGlassSurface(frame, theme, transparency)
    frame.BackgroundTransparency = transparency
    local glass = Create("ImageLabel", {
        Name = "GlassOverlay",
        BackgroundTransparency = 1,
        Image = "rbxassetid://8992230677",
        ImageColor3 = LerpColor(theme.TextPrimary, theme.Accent, 0.08),
        ImageTransparency = theme.OverlayTransparency or 0.35,
        ScaleType = Enum.ScaleType.Crop,
        Size = UDim2.fromScale(1, 1),
        ZIndex = frame.ZIndex + 1,
        Parent = frame,
    })
    Create("UIGradient", {
        Rotation = 110,
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
            ColorSequenceKeypoint.new(0.35, LerpColor(theme.Accent, Color3.new(1, 1, 1), 0.4)),
            ColorSequenceKeypoint.new(1, theme.AccentDark),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.92),
            NumberSequenceKeypoint.new(0.4, 0.97),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Parent = glass,
    })
    return glass
end

