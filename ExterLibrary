    AddGradient(mainFrame, ColorSequence.new({
        ColorSequenceKeypoint.new(0, LerpColor(theme.Background, theme.Accent, 0.06)),
        ColorSequenceKeypoint.new(1, theme.Background),
    }), 135)

    local topbar = Create("Frame", { Name = "Topbar", BackgroundColor3 = theme.Topbar,
        BackgroundTransparency = topbarTransparency,
        Size = UDim2.new(1, 0, 0, layout.TopbarHeight), BorderSizePixel = 0, Parent = mainFrame })
    Create("Frame", { Name = "CornerRepair", BackgroundColor3 = theme.Topbar,
